        </div>
      </div>

      <!-- CLOSING -->
      <div class="lng-closing">
        <div class="lng-closing-content">
          <h2 class="lng-closing-title">What you feed today defines<br>how long you <span style="color:#c084fc;">live
              tomorrow.</span></h2>
          <p class="lng-closing-sub">Fix the Root Cause. Fuel a Healthier You.</p>
          <div class="lng-closing-note">⚠️ Food choices support overall well-being. For specific medical conditions,
            consult a healthcare professional.</div>
          <div style="margin-top:48px;">
            <button class="btn btn-longevity" onclick="closeLongevityModal()" style="font-size:16px;padding:18px 44px;">
              <span>✦</span> Begin Your Longevity Journey
            </button>
          </div>
        </div>
      </div>
    </div>

    <script>
      function openLongevityModal() {
        const modal = document.getElementById('longevityModal');
        modal.classList.add('open');
        document.body.style.overflow = 'hidden';
        // Spawn particles
        spawnParticles();
      }
      function closeLongevityModal() {
        document.getElementById('longevityModal').classList.remove('open');
        document.body.style.overflow = '';
      }
      // Close on Escape
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeLongevityModal();
      });
      function spawnParticles() {
        const container = document.getElementById('lngParticles');
        if (!container || container.children.length > 0) return;
        for (let i = 0; i < 30; i++) {
          const p = document.createElement('div');
          p.className = 'lng-particle';
          const size = Math.random() * 6 + 2;
          p.style.cssText = `
      width:${size}px; height:${size}px;
      left:${Math.random() * 100}%;
      animation-duration:${Math.random() * 15 + 10}s;
      animation-delay:${Math.random() * 10}s;
      opacity:${Math.random() * 0.6 + 0.2};
      background:rgba(${Math.random() > 0.5 ? '168,85,247' : '99,102,241'},${Math.random() * 0.5 + 0.2});
    `;
          container.appendChild(p);
        }
      }
    </script>

