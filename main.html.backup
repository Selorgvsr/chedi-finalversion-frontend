<!DOCTYPE html>
<!-- saved from url=(0057)file:///C:/Users/Admin/Downloads/chedi-website%20(3).html -->
<html lang="en">

<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CHEDI – The Organic Farm</title>
  <link rel="preconnect" href="https://fonts.googleapis.com/">
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@400;500;600&family=Cormorant+Garamond:ital,wght@1,400;1,600&display=swap"
    rel="stylesheet">
  <style>
    :root {
      --green-dark: #0d2818;
      --green-mid: #1a4a2e;
      --green-light: #2d6a4f;
      --green-accent: #40916c;
      --gold: #c9963e;
      --gold-light: #e8b96a;
      --beige: #f5f0e8;
      --beige-dark: #ede5d4;
      --cream: #faf8f3;
      --white: #ffffff;
      --text-dark: #1a1a1a;
      --text-mid: #3d3d3d;
      --text-light: #6b6b6b;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--cream);
      color: var(--text-dark);
      overflow-x: hidden;
    }

    /* ── HEADER ── */
    header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      background: rgba(13, 40, 24, 0.97);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(201, 150, 62, 0.2);
      transition: box-shadow .3s;
    }

    .header-inner {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 40px;
      height: 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      text-decoration: none;
    }

    .logo-img {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      object-fit: cover;
    }

    .logo-text {
      font-family: 'Playfair Display', serif;
      font-size: 24px;
      font-weight: 700;
      color: #fff;
      letter-spacing: 1px;
    }

    .logo-sub {
      font-size: 10px;
      color: var(--gold-light);
      letter-spacing: 2px;
      text-transform: uppercase;
      display: block;
      line-height: 1;
    }

    nav {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .nav-link {
      padding: 8px 16px;
      color: rgba(255, 255, 255, .85);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      border-radius: 6px;
      transition: all .2s;
      white-space: nowrap;
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--gold-light);
      background: rgba(201, 150, 62, .1);
    }

    .dropdown {
      position: relative;
    }

    .dropdown-menu {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      background: var(--green-dark);
      border: 1px solid rgba(201, 150, 62, .2);
      border-radius: 10px;
      padding: 8px;
      min-width: 170px;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      transition: all .2s;
      box-shadow: 0 20px 40px rgba(0, 0, 0, .4);
    }

    .dropdown:hover .dropdown-menu {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .dropdown-item {
      display: block;
      padding: 10px 14px;
      color: rgba(255, 255, 255, .8);
      font-size: 13px;
      cursor: pointer;
      border-radius: 6px;
      transition: all .2s;
    }

    .dropdown-item:hover {
      background: rgba(201, 150, 62, .15);
      color: var(--gold-light);
    }

    .nav-cta {
      background: linear-gradient(135deg, var(--gold), var(--gold-light));
      color: var(--green-dark) !important;
      font-weight: 600;
      border-radius: 8px;
      margin-left: 8px;
    }

    .nav-cta:hover {
      box-shadow: 0 4px 16px rgba(201, 150, 62, .4);
      transform: translateY(-1px);
    }

    /* ── PAGES ── */
    .page {
      display: none;
    }

    .page.active {
      display: block;
    }

    /* ── BUTTONS ── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 28px;
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      transition: all .25s;
      letter-spacing: .5px;
      text-decoration: none;
    }

    .btn-gold {
      background: linear-gradient(135deg, var(--gold), var(--gold-light));
      color: var(--green-dark);
    }

    .btn-gold:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(201, 150, 62, .5);
    }

    .btn-outline {
      background: transparent;
      color: #fff;
      border: 1.5px solid rgba(255, 255, 255, .5);
    }

    .btn-outline:hover {
      background: rgba(255, 255, 255, .1);
      border-color: #fff;
      transform: translateY(-2px);
    }

    .btn-green {
      background: var(--green-mid);
      color: #fff;
    }

    .btn-green:hover {
      background: var(--green-light);
      transform: translateY(-2px);
    }

    /* ── SHARED ── */
    .container {
      max-width: 1400px;
      margin: 0 auto;
    }

    .section-tag {
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 12px;
    }

    .section-heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(30px, 4vw, 50px);
      font-weight: 700;
      line-height: 1.15;
      color: var(--green-dark);
    }

    .section-heading.white {
      color: #fff;
    }

    .section-sub {
      font-size: 17px;
      line-height: 1.7;
      color: var(--text-light);
      max-width: 560px;
    }

    .section-sub.white {
      color: rgba(255, 255, 255, .72);
    }

    .section-header {
      text-align: center;
      margin-bottom: 56px;
    }

    .section-header .section-sub {
      margin: 14px auto 0;
    }

    .cta-btns {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    .cta-btns.center {
      justify-content: center;
    }

    /* ── IMAGE UTILITIES ── */
    .img-cover {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .img-rounded {
      border-radius: 20px;
      overflow: hidden;
    }

    .img-overlay {
      position: relative;
    }

    .img-overlay::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
    }

    /* ── TWO-COL ── */
    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 72px;
      align-items: center;
    }

    .two-col.reverse {
      direction: rtl;
    }

    .two-col.reverse>* {
      direction: ltr;
    }

    /* ── FOOTER ── */
    footer {
      background: #030d05;
      padding: 60px 40px 28px;
      border-top: 1px solid rgba(201, 150, 62, .14);
    }

    .footer-inner {
      max-width: 1400px;
      margin: 0 auto;
    }

    .footer-top {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 52px;
      margin-bottom: 44px;
    }

    .footer-brand p {
      font-size: 14px;
      line-height: 1.7;
      color: rgba(255, 255, 255, .38);
      margin-top: 14px;
      max-width: 270px;
    }

    .footer-col h4 {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 18px;
    }

    .footer-col a {
      display: block;
      font-size: 14px;
      color: rgba(255, 255, 255, .48);
      margin-bottom: 9px;
      cursor: pointer;
      transition: color .2s;
      text-decoration: none;
    }

    .footer-col a:hover {
      color: #fff;
    }

    .footer-contact p {
      font-size: 14px;
      color: rgba(255, 255, 255, .48);
      margin-bottom: 8px;
    }

    .footer-bottom {
      border-top: 1px solid rgba(255, 255, 255, .06);
      padding-top: 22px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }

    .footer-bottom p {
      font-size: 13px;
      color: rgba(255, 255, 255, .28);
    }

    .footer-legal-links {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .footer-legal-link {
      font-size: 13px;
      color: rgba(255, 255, 255, .38);
      text-decoration: none;
      cursor: pointer;
      transition: color .2s;
      letter-spacing: .2px;
    }

    .footer-legal-link:hover {
      color: rgba(255, 255, 255, .85);
    }

    .footer-legal-sep {
      font-size: 11px;
      color: rgba(255, 255, 255, .14);
      user-select: none;
    }

    .social-icons {
      display: flex;
      gap: 9px;
    }

    .social-icon {
      width: 34px;
      height: 34px;
      border-radius: 8px;
      background: rgba(255, 255, 255, .06);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all .2s;
      font-size: 13px;
      color: rgba(255, 255, 255, .5);
    }

    .social-icon:hover {
      background: var(--gold);
      color: var(--green-dark);
    }

    /* ─────────────────────────────────────────
   HOME PAGE
───────────────────────────────────────── */
    .home-hero {
      min-height: 100vh;
      position: relative;
      display: flex;
      align-items: center;
      overflow: hidden;
      padding-top: 72px;
    }

    .home-hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      background-image: url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=1800&q=80');
      background-size: cover;
      background-position: center;
    }

    .home-hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(100deg, rgba(4, 16, 10, .92) 0%, rgba(13, 40, 24, .82) 55%, rgba(26, 74, 46, .55) 100%);
    }

    .home-hero-content {
      position: relative;
      z-index: 2;
      max-width: 1400px;
      margin: 0 auto;
      padding: 80px 40px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(201, 150, 62, .15);
      border: 1px solid rgba(201, 150, 62, .3);
      border-radius: 50px;
      padding: 6px 16px;
      margin-bottom: 26px;
    }

    .hero-badge span {
      font-size: 12px;
      font-weight: 500;
      color: var(--gold-light);
      letter-spacing: 1px;
    }

    .hero-dot {
      width: 6px;
      height: 6px;
      background: var(--gold);
      border-radius: 50%;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 1;
        transform: scale(1)
      }

      50% {
        opacity: .5;
        transform: scale(.8)
      }
    }

    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(40px, 5vw, 68px);
      font-weight: 900;
      line-height: 1.08;
      color: #fff;
      margin-bottom: 20px;
    }

    .hero-title .gold {
      color: var(--gold-light);
    }

    .hero-sub {
      font-size: 18px;
      line-height: 1.72;
      color: rgba(255, 255, 255, .7);
      margin-bottom: 38px;
      max-width: 500px;
    }

    .hero-stats {
      display: flex;
      gap: 36px;
      margin-top: 48px;
    }

    .hero-stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 30px;
      font-weight: 700;
      color: var(--gold-light);
    }

    .hero-stat-label {
      font-size: 12px;
      color: rgba(255, 255, 255, .48);
      margin-top: 3px;
    }

    /* Hero right image card */
    .hero-img-card {
      border-radius: 20px;
      overflow: hidden;
      position: relative;
      height: 480px;
      box-shadow: 0 32px 80px rgba(0, 0, 0, .5);
    }

    .hero-img-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .hero-img-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(13, 40, 24, .8) 0%, transparent 50%);
    }

    .hero-img-badge {
      position: absolute;
      bottom: 24px;
      left: 24px;
      right: 24px;
      background: rgba(255, 255, 255, .1);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, .2);
      border-radius: 14px;
      padding: 18px 22px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .hero-img-badge-stat {
      text-align: center;
    }

    .hero-img-badge-stat .n {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      font-weight: 700;
      color: var(--gold-light);
    }

    .hero-img-badge-stat .l {
      font-size: 11px;
      color: rgba(255, 255, 255, .6);
      margin-top: 2px;
    }

    .eco-pill-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .eco-pill {
      display: flex;
      align-items: center;
      gap: 12px;
      background: rgba(255, 255, 255, .06);
      border: 1px solid rgba(255, 255, 255, .08);
      border-radius: 10px;
      padding: 12px 16px;
      cursor: pointer;
      transition: all .25s;
    }

    .eco-pill:hover {
      background: rgba(201, 150, 62, .1);
      border-color: rgba(201, 150, 62, .3);
      transform: translateX(4px);
    }

    .eco-pill-icon {
      width: 34px;
      height: 34px;
      background: linear-gradient(135deg, var(--green-accent), var(--gold));
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      flex-shrink: 0;
    }

    .eco-pill-text {
      color: rgba(255, 255, 255, .82);
      font-size: 13px;
      font-weight: 500;
    }

    .eco-pill-sub {
      font-size: 11px;
      color: rgba(255, 255, 255, .38);
      margin-top: 2px;
    }

    /* Problem */
    .problem-section {
      padding: 100px 40px;
      background: var(--green-dark);
      position: relative;
      overflow: hidden;
    }

    .problem-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
    }

    .problem-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }

    .problem-card {
      background: rgba(255, 255, 255, .04);
      border: 1px solid rgba(255, 255, 255, .08);
      border-radius: 18px;
      overflow: hidden;
      transition: all .3s;
    }

    .problem-card:hover {
      transform: translateY(-5px);
      border-color: rgba(201, 150, 62, .3);
    }

    .problem-card-img {
      height: 160px;
      overflow: hidden;
    }

    .problem-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .4s;
    }

    .problem-card:hover .problem-card-img img {
      transform: scale(1.06);
    }

    .problem-card-body {
      padding: 22px 20px;
    }

    .problem-card-title {
      font-family: 'Playfair Display', serif;
      font-size: 17px;
      color: #fff;
      margin-bottom: 8px;
    }

    .problem-card-desc {
      font-size: 13px;
      line-height: 1.6;
      color: rgba(255, 255, 255, .48);
    }

    .problem-closing {
      text-align: center;
      margin-top: 56px;
      padding-top: 56px;
      border-top: 1px solid rgba(255, 255, 255, .07);
    }

    .problem-closing p {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      color: #fff;
      font-style: italic;
    }

    .problem-closing span {
      color: var(--gold-light);
    }

    /* Ecosystem */
    .ecosystem-section {
      padding: 100px 40px;
      background: var(--beige);
    }

    .eco-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .eco-card {
      background: #fff;
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid rgba(0, 0, 0, .06);
      transition: all .3s;
      position: relative;
    }

    .eco-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--green-light), var(--gold));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform .3s;
      z-index: 2;
    }

    .eco-card:hover::before {
      transform: scaleX(1);
    }

    .eco-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, .1);
    }

    .eco-card-img {
      height: 180px;
      overflow: hidden;
      position: relative;
    }

    .eco-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .4s;
    }

    .eco-card:hover .eco-card-img img {
      transform: scale(1.06);
    }

    .eco-card-body {
      padding: 24px;
    }

    .eco-card-title {
      font-family: 'Playfair Display', serif;
      font-size: 19px;
      color: var(--green-dark);
      margin-bottom: 8px;
    }

    .eco-card-desc {
      font-size: 13px;
      line-height: 1.65;
      color: var(--text-light);
    }

    /* Story */
    .story-section {
      padding: 100px 40px;
      background: var(--cream);
    }

    .story-img {
      border-radius: 20px;
      overflow: hidden;
      height: 500px;
      position: relative;
      box-shadow: 0 24px 60px rgba(0, 0, 0, .15);
    }

    .story-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .story-img-badge {
      position: absolute;
      bottom: 24px;
      left: 24px;
      background: rgba(255, 255, 255, .12);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, .2);
      border-radius: 12px;
      padding: 16px 20px;
    }

    .story-img-badge h4 {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      color: var(--gold-light);
    }

    .story-img-badge p {
      font-size: 12px;
      color: rgba(255, 255, 255, .65);
      margin-top: 3px;
    }

    .story-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin-top: 28px;
    }

    .stat-item {
      background: var(--beige);
      border-radius: 12px;
      padding: 18px;
      border-left: 3px solid var(--gold);
    }

    .stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      font-weight: 700;
      color: var(--green-dark);
    }

    .stat-label {
      font-size: 13px;
      color: var(--text-light);
      margin-top: 3px;
    }

    /* Farmer */
    .farmer-section {
      padding: 100px 40px;
      background: var(--green-dark);
    }

    .farmer-img {
      border-radius: 20px;
      overflow: hidden;
      height: 520px;
      position: relative;
      box-shadow: 0 24px 60px rgba(0, 0, 0, .4);
    }

    .farmer-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .farmer-img::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(13, 40, 24, .5) 0%, transparent 60%);
      border-radius: 20px;
    }

    .farmer-features {
      display: flex;
      flex-direction: column;
      gap: 14px;
      margin-top: 28px;
    }

    .farmer-feature {
      display: flex;
      gap: 14px;
      align-items: flex-start;
      background: rgba(255, 255, 255, .05);
      border-radius: 12px;
      padding: 16px 18px;
      border: 1px solid rgba(255, 255, 255, .07);
      transition: all .25s;
    }

    .farmer-feature:hover {
      background: rgba(201, 150, 62, .08);
      border-color: rgba(201, 150, 62, .2);
    }

    .farmer-feature-icon {
      width: 38px;
      height: 38px;
      background: linear-gradient(135deg, var(--green-accent), var(--gold));
      border-radius: 9px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 17px;
      flex-shrink: 0;
    }

    .farmer-feature-title {
      font-size: 14px;
      font-weight: 600;
      color: #fff;
      margin-bottom: 3px;
    }

    .farmer-feature-desc {
      font-size: 12px;
      color: rgba(255, 255, 255, .48);
      line-height: 1.5;
    }

    /* Models Preview */
    .models-section {
      padding: 100px 40px;
      background: var(--beige-dark);
    }

    .models-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      margin-top: 48px;
    }

    .model-card {
      border-radius: 22px;
      overflow: hidden;
      position: relative;
      transition: all .3s;
    }

    .model-card:hover {
      transform: translateY(-6px);
    }

    .model-card-img {
      height: 260px;
      overflow: hidden;
      position: relative;
    }

    .model-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .4s;
    }

    .model-card:hover .model-card-img img {
      transform: scale(1.05);
    }

    .model-card-img-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(13, 40, 24, .9) 0%, rgba(13, 40, 24, .3) 100%);
    }

    .model-card-body {
      background: linear-gradient(135deg, var(--green-dark), var(--green-mid));
      padding: 30px;
      border: 1px solid rgba(201, 150, 62, .15);
      border-top: none;
    }

    .model-badge {
      display: inline-block;
      background: rgba(201, 150, 62, .2);
      border: 1px solid rgba(201, 150, 62, .4);
      color: var(--gold-light);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 4px 12px;
      border-radius: 50px;
      margin-bottom: 12px;
    }

    .model-title {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      color: #fff;
      margin-bottom: 10px;
    }

    .model-desc {
      font-size: 13px;
      line-height: 1.65;
      color: rgba(255, 255, 255, .58);
      margin-bottom: 22px;
    }

    .model-highlight {
      display: flex;
      align-items: center;
      gap: 9px;
      font-size: 13px;
      color: rgba(255, 255, 255, .72);
      margin-bottom: 7px;
    }

    .model-highlight::before {
      content: '✓';
      width: 18px;
      height: 18px;
      background: var(--gold);
      color: var(--green-dark);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-weight: 700;
      flex-shrink: 0;
    }

    /* Tech */
    .tech-section {
      padding: 100px 40px;
      background: var(--cream);
    }

    .tech-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
      margin-top: 48px;
    }

    .tech-card {
      background: #fff;
      border: 1px solid rgba(0, 0, 0, .06);
      border-radius: 16px;
      overflow: hidden;
      transition: all .25s;
      cursor: default;
    }

    .tech-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 28px rgba(0, 0, 0, .1);
    }

    .tech-card-img {
      height: 110px;
      overflow: hidden;
    }

    .tech-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .4s;
    }

    .tech-card:hover .tech-card-img img {
      transform: scale(1.08);
    }

    .tech-card-body {
      padding: 14px;
    }

    .tech-card-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--green-dark);
      margin-bottom: 4px;
    }

    .tech-card-desc {
      font-size: 11px;
      color: var(--text-light);
      line-height: 1.45;
    }

    /* Impact */
    .impact-section {
      padding: 80px 40px;
      background: linear-gradient(135deg, var(--green-dark), #0a1f12);
    }

    .impact-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 18px;
      margin-top: 48px;
    }

    .impact-card {
      text-align: center;
      padding: 28px 16px;
      background: rgba(255, 255, 255, .04);
      border: 1px solid rgba(255, 255, 255, .07);
      border-radius: 16px;
      transition: all .25s;
    }

    .impact-card:hover {
      background: rgba(201, 150, 62, .08);
      border-color: rgba(201, 150, 62, .25);
    }

    .impact-icon {
      font-size: 26px;
      margin-bottom: 12px;
    }

    .impact-num {
      font-family: 'Playfair Display', serif;
      font-size: 34px;
      font-weight: 700;
      color: var(--gold-light);
      line-height: 1;
      margin-bottom: 6px;
    }

    .impact-label {
      font-size: 12px;
      color: rgba(255, 255, 255, .48);
    }

    /* CTA Banner */
    .cta-banner {
      padding: 100px 40px;
      position: relative;
      overflow: hidden;
      text-align: center;
    }

    .cta-banner-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .cta-banner-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .cta-banner-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(13, 40, 24, .88);
    }

    .cta-banner-content {
      position: relative;
      z-index: 2;
    }

    .cta-banner-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(34px, 4vw, 54px);
      font-weight: 700;
      color: #fff;
      margin-bottom: 14px;
    }

    .cta-banner-sub {
      font-size: 18px;
      color: rgba(255, 255, 255, .6);
      margin-bottom: 38px;
      max-width: 540px;
      margin-left: auto;
      margin-right: auto;
    }

    /* ─────────────────────────────────────────
   LAND PAGE
───────────────────────────────────────── */
    .land-hero {
      min-height: 100vh;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding-top: 72px;
      overflow: hidden;
    }

    .land-hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .land-hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
    }

    .land-hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(160deg, rgba(4, 14, 8, .92) 0%, rgba(13, 40, 24, .84) 55%, rgba(26, 74, 46, .7) 100%);
    }

    .land-hero-content {
      position: relative;
      z-index: 2;
      padding: 60px 40px;
    }

    .land-hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(70px, 12vw, 130px);
      font-weight: 900;
      color: #fff;
      line-height: .9;
      margin-bottom: 14px;
      letter-spacing: -3px;
    }

    .land-hero-subtitle {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(22px, 3vw, 36px);
      color: var(--gold-light);
      font-style: italic;
      margin-bottom: 22px;
    }

    .land-hero-desc {
      font-size: 17px;
      color: rgba(255, 255, 255, .62);
      max-width: 560px;
      margin: 0 auto 38px;
      line-height: 1.72;
    }

    .land-pills {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 44px;
    }

    .land-pill {
      background: rgba(255, 255, 255, .08);
      border: 1px solid rgba(255, 255, 255, .13);
      border-radius: 50px;
      padding: 8px 18px;
      font-size: 13px;
      color: rgba(255, 255, 255, .8);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .land-pill::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--gold);
      flex-shrink: 0;
    }

    /* Why Land */
    .why-land {
      padding: 100px 40px;
      background: var(--cream);
    }

    .flow-diagram {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
    }

    .flow-item {
      display: flex;
      align-items: center;
      gap: 14px;
      width: 100%;
      background: #fff;
      border: 1px solid rgba(0, 0, 0, .06);
      border-radius: 12px;
      padding: 14px 20px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, .04);
    }

    .flow-arrow-line {
      width: 2px;
      height: 28px;
      background: linear-gradient(var(--green-accent), var(--gold));
      margin: 0 auto;
    }

    .flow-icon {
      width: 38px;
      height: 38px;
      background: linear-gradient(135deg, var(--green-mid), var(--green-accent));
      border-radius: 9px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 17px;
      flex-shrink: 0;
    }

    .flow-label {
      font-size: 15px;
      font-weight: 600;
      color: var(--green-dark);
    }

    /* Land Purchasing */
    .land-purchase {
      padding: 100px 40px;
      background: var(--beige);
    }

    .content-card-item {
      background: #fff;
      border-radius: 12px;
      padding: 20px 22px;
      border-left: 3px solid var(--green-accent);
      margin-bottom: 14px;
      transition: all .25s;
      box-shadow: 0 2px 8px rgba(0, 0, 0, .04);
    }

    .content-card-item:hover {
      transform: translateX(4px);
      border-left-color: var(--gold);
    }

    .content-card-item h4 {
      font-size: 15px;
      font-weight: 600;
      color: var(--green-dark);
      margin-bottom: 5px;
    }

    .content-card-item p {
      font-size: 13px;
      color: var(--text-light);
      line-height: 1.5;
    }

    /* Timeline */
    .process-section {
      padding: 100px 40px;
      background: var(--cream);
    }

    .timeline {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 0;
      position: relative;
      margin-top: 56px;
    }

    .timeline::before {
      content: '';
      position: absolute;
      top: 36px;
      left: calc(100%/12);
      right: calc(100%/12);
      height: 2px;
      background: linear-gradient(90deg, var(--green-light), var(--gold));
      z-index: 0;
    }

    .timeline-step {
      text-align: center;
      position: relative;
      z-index: 1;
      padding: 0 8px;
    }

    .timeline-num {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--green-mid), var(--green-accent));
      color: #fff;
      font-family: 'Playfair Display', serif;
      font-size: 24px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 18px;
      border: 3px solid var(--cream);
      box-shadow: 0 4px 16px rgba(13, 40, 24, .2);
    }

    .timeline-step-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--green-dark);
      margin-bottom: 5px;
    }

    .timeline-step-desc {
      font-size: 11px;
      color: var(--text-light);
      line-height: 1.5;
    }

    /* Leasing */
    .leasing-section {
      padding: 100px 40px;
      background: var(--green-dark);
    }

    .leasing-img {
      border-radius: 20px;
      overflow: hidden;
      height: 420px;
      box-shadow: 0 24px 60px rgba(0, 0, 0, .4);
    }

    .leasing-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .dashboard-card {
      background: rgba(255, 255, 255, .04);
      border: 1px solid rgba(255, 255, 255, .08);
      border-radius: 20px;
      padding: 28px;
    }

    .dash-row {
      background: rgba(255, 255, 255, .06);
      border-radius: 10px;
      padding: 14px 18px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }

    .dash-row span {
      color: rgba(255, 255, 255, .68);
      font-size: 14px;
    }

    .dash-row strong {
      font-family: 'Playfair Display', serif;
      font-size: 20px;
      color: var(--gold-light);
    }

    /* Metrics */
    .metrics-section {
      padding: 80px 40px;
      background: linear-gradient(135deg, var(--green-dark), #0a1f12);
    }

    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
      margin-top: 48px;
    }

    /* Sustainability */
    .sustain-section {
      padding: 100px 40px;
      background: var(--cream);
      position: relative;
      overflow: hidden;
    }

    .sustain-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .sustain-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .sustain-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(250, 248, 243, .93);
    }

    .sustain-content {
      position: relative;
      z-index: 2;
      text-align: center;
    }

    .sustain-icons {
      display: flex;
      gap: 28px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 40px;
    }

    .sustain-item {
      text-align: center;
    }

    .sustain-icon {
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, var(--green-light), var(--green-accent));
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 26px;
      margin: 0 auto 10px;
    }

    .sustain-label {
      font-size: 13px;
      font-weight: 600;
      color: var(--green-dark);
    }

    /* Partnership */
    .partnership-section {
      padding: 100px 40px;
      background: var(--beige);
    }

    .partner-img {
      border-radius: 20px;
      overflow: hidden;
      height: 460px;
      box-shadow: 0 20px 48px rgba(0, 0, 0, .12);
    }

    .partner-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* ─────────────────────────────────────────
   FARMER PAGE
───────────────────────────────────────── */
    .farmer-hero {
      min-height: 100vh;
      position: relative;
      display: flex;
      align-items: center;
      padding-top: 72px;
      overflow: hidden;
    }

    .farmer-hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .farmer-hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
    }

    .farmer-hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(100deg, rgba(10, 31, 16, .94) 0%, rgba(26, 74, 46, .82) 55%, rgba(13, 40, 24, .4) 100%);
    }

    .farmer-hero-content {
      position: relative;
      z-index: 2;
      max-width: 1400px;
      margin: 0 auto;
      padding: 80px 40px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 72px;
      align-items: center;
    }

    .farmer-hero-tag {
      font-size: 12px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 12px;
    }

    .farmer-hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(44px, 5vw, 72px);
      font-weight: 900;
      color: #fff;
      line-height: 1.05;
      margin-bottom: 10px;
    }

    .farmer-hero-title .highlight {
      color: var(--gold-light);
      font-style: italic;
    }

    .farmer-hero-sub {
      font-size: 16px;
      color: rgba(255, 255, 255, .6);
      line-height: 1.72;
      margin-bottom: 34px;
      max-width: 440px;
    }

    .dual-value {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 32px;
    }

    .value-block {
      border-radius: 12px;
      padding: 17px;
    }

    .value-block-1 {
      background: rgba(201, 150, 62, .15);
      border: 1px solid rgba(201, 150, 62, .3);
    }

    .value-block-2 {
      background: rgba(255, 255, 255, .07);
      border: 1px solid rgba(255, 255, 255, .12);
    }

    .value-block h4 {
      font-size: 14px;
      font-weight: 600;
      color: #fff;
      margin-bottom: 4px;
    }

    .value-block p {
      font-size: 12px;
      color: rgba(255, 255, 255, .52);
    }

    .farmer-hero-img {
      border-radius: 20px;
      overflow: hidden;
      height: 460px;
      box-shadow: 0 32px 80px rgba(0, 0, 0, .5);
    }

    .farmer-hero-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Built Around */
    .built-section {
      padding: 100px 40px;
      background: var(--cream);
    }

    .built-img {
      border-radius: 20px;
      overflow: hidden;
      height: 440px;
      box-shadow: 0 20px 48px rgba(0, 0, 0, .12);
    }

    .built-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Learning */
    .learning-section {
      padding: 100px 40px;
      background: var(--green-dark);
    }

    .learning-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 72px;
      align-items: center;
    }

    .feature-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 26px;
    }

    .feature-chip {
      background: rgba(255, 255, 255, .08);
      border: 1px solid rgba(255, 255, 255, .12);
      border-radius: 50px;
      padding: 7px 15px;
      font-size: 13px;
      color: rgba(255, 255, 255, .8);
      display: flex;
      align-items: center;
      gap: 6px;
      transition: all .2s;
    }

    .feature-chip:hover {
      background: rgba(201, 150, 62, .15);
      border-color: rgba(201, 150, 62, .4);
      color: var(--gold-light);
    }

    .feature-chip .dot {
      width: 5px;
      height: 5px;
      background: var(--gold);
      border-radius: 50%;
    }

    .app-img {
      border-radius: 20px;
      overflow: hidden;
      height: 400px;
      box-shadow: 0 24px 60px rgba(0, 0, 0, .4);
    }

    .app-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Training */
    .training-section {
      padding: 100px 40px;
      background: var(--beige-dark);
    }

    .training-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-top: 48px;
    }

    .training-card {
      background: #fff;
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid rgba(0, 0, 0, .06);
      transition: all .3s;
    }

    .training-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, .08);
    }

    .training-card-img {
      height: 220px;
      overflow: hidden;
    }

    .training-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .4s;
    }

    .training-card:hover .training-card-img img {
      transform: scale(1.05);
    }

    .training-card-body {
      padding: 28px;
    }

    .training-card-title {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      color: var(--green-dark);
      margin-bottom: 10px;
    }

    .training-card-desc {
      font-size: 14px;
      line-height: 1.65;
      color: var(--text-light);
      margin-bottom: 20px;
    }

    /* Tech Tools */
    .tech-tools-section {
      padding: 100px 40px;
      background: var(--cream);
    }

    .tech-tools-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
      margin-top: 48px;
    }

    .tool-card {
      background: #fff;
      border: 1px solid rgba(0, 0, 0, .06);
      border-radius: 16px;
      overflow: hidden;
      transition: all .3s;
    }

    .tool-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 28px rgba(0, 0, 0, .08);
    }

    .tool-card-img {
      height: 140px;
      overflow: hidden;
      position: relative;
    }

    .tool-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .4s;
    }

    .tool-card:hover .tool-card-img img {
      transform: scale(1.06);
    }

    .tool-card-body {
      padding: 20px;
    }

    .tool-card-title {
      font-family: 'Playfair Display', serif;
      font-size: 15px;
      color: var(--green-dark);
      margin-bottom: 8px;
    }

    .tool-card-desc {
      font-size: 12px;
      line-height: 1.6;
      color: var(--text-light);
    }

    /* Journey */
    .journey-section {
      padding: 100px 40px;
      position: relative;
      text-align: center;
      overflow: hidden;
    }

    .journey-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .journey-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .journey-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(13, 40, 24, .9);
    }

    .journey-content {
      position: relative;
      z-index: 2;
    }

    .journey-steps {
      display: flex;
      gap: 36px;
      justify-content: center;
      align-items: center;
      margin-top: 48px;
      flex-wrap: wrap;
    }

    .journey-step {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .journey-step-num {
      width: 54px;
      height: 54px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--gold), var(--gold-light));
      color: var(--green-dark);
      font-family: 'Playfair Display', serif;
      font-size: 20px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .journey-step-text {
      font-size: 15px;
      color: rgba(255, 255, 255, .8);
      font-weight: 500;
      text-align: left;
    }

    .journey-arrow {
      font-size: 22px;
      color: rgba(255, 255, 255, .2);
    }

    /* ─────────────────────────────────────────
   MODEL PAGES
───────────────────────────────────────── */
    .model-hero {
      min-height: 100vh;
      position: relative;
      display: flex;
      align-items: center;
      padding-top: 72px;
      overflow: hidden;
    }

    .model-hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .model-hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .model-1-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(110deg, rgba(13, 40, 24, .95) 0%, rgba(26, 74, 46, .85) 55%, rgba(13, 40, 24, .5) 100%);
    }

    .model-2-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(110deg, rgba(10, 10, 5, .96) 0%, rgba(26, 26, 13, .88) 55%, rgba(13, 40, 24, .55) 100%);
    }

    .model-hero-content {
      position: relative;
      z-index: 2;
      max-width: 1400px;
      margin: 0 auto;
      padding: 80px 40px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 72px;
      align-items: center;
    }

    .model-steps-card {
      background: rgba(255, 255, 255, .06);
      border: 1px solid rgba(255, 255, 255, .1);
      border-radius: 20px;
      padding: 30px;
      backdrop-filter: blur(8px);
    }

    .model-steps-label {
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 18px;
    }

    .model-step {
      display: flex;
      align-items: flex-start;
      gap: 13px;
      background: rgba(255, 255, 255, .05);
      border-radius: 10px;
      padding: 13px 16px;
      border: 1px solid rgba(255, 255, 255, .06);
      margin-bottom: 10px;
    }

    .model-step-num {
      width: 26px;
      height: 26px;
      background: var(--gold);
      color: var(--green-dark);
      border-radius: 50%;
      font-size: 12px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .model-step-text {
      font-size: 13px;
      color: rgba(255, 255, 255, .72);
      line-height: 1.5;
    }

    .model-benefits-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin-top: 26px;
    }

    .model-benefit-card {
      background: #fff;
      border: 1px solid rgba(0, 0, 0, .06);
      border-radius: 14px;
      padding: 20px;
      transition: all .25s;
    }

    .model-benefit-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 24px rgba(0, 0, 0, .08);
    }

    .model-benefit-icon-lg {
      font-size: 26px;
      margin-bottom: 9px;
    }

    .model-benefit-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--green-dark);
      margin-bottom: 5px;
    }

    .model-benefit-desc {
      font-size: 12px;
      color: var(--text-light);
      line-height: 1.5;
    }

    .best-for-tags {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .best-for-tag {
      background: rgba(201, 150, 62, .15);
      border: 1px solid rgba(201, 150, 62, .3);
      border-radius: 50px;
      padding: 5px 13px;
      font-size: 12px;
      color: var(--gold-light);
    }

    /* Model image strip */
    .model-img-strip {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-top: 56px;
    }

    .model-strip-img {
      border-radius: 14px;
      overflow: hidden;
      height: 200px;
    }

    .model-strip-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .4s;
    }

    .model-strip-img:hover img {
      transform: scale(1.05);
    }

    /* ─────────────────────────────────────────
   CSA PAGE
───────────────────────────────────────── */
    .csa-hero {
      min-height: 100vh;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding-top: 72px;
      overflow: hidden;
    }

    .csa-hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .csa-hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 60%;
    }

    .csa-hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(160deg, rgba(4, 14, 8, .9) 0%, rgba(13, 40, 24, .82) 55%, rgba(26, 74, 46, .65) 100%);
    }

    .csa-hero-content {
      position: relative;
      z-index: 2;
      max-width: 800px;
      margin: 0 auto;
      padding: 80px 40px;
    }

    .csa-hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(40px, 6vw, 70px);
      font-weight: 900;
      color: #fff;
      line-height: 1.1;
      margin-bottom: 18px;
    }

    .csa-hero-title .italic {
      font-style: italic;
      color: var(--gold-light);
    }

    .csa-hero-desc {
      font-size: 18px;
      line-height: 1.72;
      color: rgba(255, 255, 255, .65);
      margin-bottom: 38px;
    }

    .csa-features {
      display: flex;
      gap: 18px;
      justify-content: center;
      flex-wrap: wrap;
      margin: 44px 0;
    }

    .csa-feature {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 7px;
    }

    .csa-feature-icon {
      width: 50px;
      height: 50px;
      background: rgba(255, 255, 255, .09);
      border: 1px solid rgba(255, 255, 255, .13);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 21px;
    }

    .csa-feature-label {
      font-size: 11px;
      color: rgba(255, 255, 255, .52);
      text-align: center;
      max-width: 75px;
    }

    /* CSA Stats */
    .csa-stats-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
    }

    /* Plans */
    .plans-section {
      padding: 100px 40px;
      background: var(--cream);
    }

    .plans-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
      margin-top: 48px;
    }

    .plan-card {
      background: #fff;
      border-radius: 20px;
      padding: 34px 26px;
      border: 1px solid rgba(0, 0, 0, .07);
      position: relative;
      transition: all .3s;
    }

    .plan-card.featured {
      background: var(--green-dark);
      border-color: var(--gold);
      transform: scale(1.03);
      box-shadow: 0 24px 60px rgba(13, 40, 24, .25);
    }

    .plan-card:hover:not(.featured) {
      transform: translateY(-6px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, .08);
    }

    .plan-badge {
      position: absolute;
      top: -13px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--gold);
      color: var(--green-dark);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 4px 13px;
      border-radius: 50px;
      white-space: nowrap;
    }

    .plan-name {
      font-family: 'Playfair Display', serif;
      font-size: 23px;
      color: var(--green-dark);
      margin-bottom: 7px;
    }

    .featured .plan-name {
      color: #fff;
    }

    .plan-price {
      font-family: 'Playfair Display', serif;
      font-size: 38px;
      font-weight: 700;
      color: var(--green-dark);
      line-height: 1;
      margin-bottom: 4px;
    }

    .featured .plan-price {
      color: var(--gold-light);
    }

    .plan-per {
      font-size: 13px;
      color: var(--text-light);
      margin-bottom: 22px;
    }

    .featured .plan-per {
      color: rgba(255, 255, 255, .48);
    }

    .plan-feature {
      display: flex;
      align-items: center;
      gap: 9px;
      font-size: 13px;
      color: var(--text-mid);
      margin-bottom: 9px;
    }

    .featured .plan-feature {
      color: rgba(255, 255, 255, .72);
    }

    .plan-feature::before {
      content: '✓';
      width: 17px;
      height: 17px;
      background: var(--green-light);
      color: #fff;
      border-radius: 50%;
      font-size: 9px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    /* CSA Story */
    .csa-story-img {
      border-radius: 20px;
      overflow: hidden;
      height: 480px;
      box-shadow: 0 24px 60px rgba(0, 0, 0, .15);
    }

    .csa-story-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Delivery */
    .delivery-section {
      padding: 100px 40px;
      background: var(--beige);
    }

    .delivery-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      margin-top: 48px;
    }

    .delivery-card {
      background: #fff;
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid rgba(0, 0, 0, .06);
      transition: all .3s;
      display: flex;
    }

    .delivery-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 28px rgba(0, 0, 0, .08);
    }

    .delivery-card-img {
      width: 120px;
      flex-shrink: 0;
    }

    .delivery-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .delivery-card-body {
      padding: 18px 20px;
    }

    .delivery-card-title {
      font-size: 15px;
      font-weight: 600;
      color: var(--green-dark);
      margin-bottom: 6px;
    }

    .delivery-card-desc {
      font-size: 13px;
      color: var(--text-light);
      line-height: 1.55;
    }

    /* ─────────────────────────────────────────
   ABOUT PAGE
───────────────────────────────────────── */
    .about-hero {
      min-height: 80vh;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding-top: 72px;
      overflow: hidden;
    }

    .about-hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .about-hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
    }

    .about-hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(13, 40, 24, .84);
    }

    .about-hero-content {
      position: relative;
      z-index: 2;
      max-width: 800px;
      margin: 0 auto;
      padding: 80px 40px;
    }

    /* Mission */
    .mission-section {
      padding: 100px 40px;
      background: var(--beige);
    }

    .mission-pillars {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
      margin-top: 48px;
    }

    .pillar-card {
      background: #fff;
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid rgba(0, 0, 0, .06);
      transition: all .25s;
    }

    .pillar-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 16px 32px rgba(0, 0, 0, .08);
    }

    .pillar-card-img {
      height: 120px;
      overflow: hidden;
    }

    .pillar-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .4s;
    }

    .pillar-card:hover .pillar-card-img img {
      transform: scale(1.06);
    }

    .pillar-card-body {
      padding: 20px;
    }

    .pillar-icon {
      font-size: 24px;
      margin-bottom: 8px;
    }

    .pillar-title {
      font-family: 'Playfair Display', serif;
      font-size: 17px;
      color: var(--green-dark);
      margin-bottom: 6px;
    }

    .pillar-desc {
      font-size: 12px;
      color: var(--text-light);
      line-height: 1.55;
    }

    /* Revenue */
    .revenue-section {
      padding: 100px 40px;
      background: var(--green-dark);
    }

    .revenue-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
      margin-top: 48px;
    }

    .revenue-card {
      background: rgba(255, 255, 255, .05);
      border: 1px solid rgba(255, 255, 255, .08);
      border-radius: 14px;
      overflow: hidden;
      transition: all .25s;
    }

    .revenue-card:hover {
      background: rgba(201, 150, 62, .1);
      border-color: rgba(201, 150, 62, .3);
      transform: translateY(-4px);
    }

    .revenue-card-img {
      height: 100px;
      overflow: hidden;
    }

    .revenue-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .4s;
      opacity: .7;
    }

    .revenue-card:hover .revenue-card-img img {
      transform: scale(1.06);
      opacity: .9;
    }

    .revenue-card-body {
      padding: 16px;
    }

    .revenue-title {
      font-size: 13px;
      font-weight: 600;
      color: #fff;
      margin-bottom: 6px;
      line-height: 1.4;
    }

    .revenue-desc {
      font-size: 11px;
      color: rgba(255, 255, 255, .42);
      line-height: 1.5;
    }

    /* Carbon */
    .carbon-section {
      padding: 100px 40px;
      background: var(--cream);
    }

    .carbon-img {
      border-radius: 20px;
      overflow: hidden;
      height: 420px;
      position: relative;
      box-shadow: 0 20px 48px rgba(0, 0, 0, .12);
    }

    .carbon-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .carbon-img::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(13, 40, 24, .7) 0%, transparent 55%);
      border-radius: 20px;
    }

    .carbon-img-badge {
      position: absolute;
      bottom: 24px;
      left: 24px;
      background: rgba(255, 255, 255, .12);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, .2);
      border-radius: 12px;
      padding: 14px 18px;
      z-index: 2;
    }

    .carbon-points {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 13px;
      margin-top: 22px;
    }

    .carbon-point {
      background: var(--beige);
      border-radius: 12px;
      padding: 16px;
      border-left: 3px solid var(--green-accent);
    }

    .carbon-point h4 {
      font-size: 13px;
      font-weight: 600;
      color: var(--green-dark);
      margin-bottom: 3px;
    }

    .carbon-point p {
      font-size: 12px;
      color: var(--text-light);
    }

    /* Why CHEDI */
    .why-section {
      padding: 100px 40px;
      background: var(--green-dark);
    }

    .why-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      margin-top: 48px;
    }

    .why-card {
      border-radius: 18px;
      overflow: hidden;
      transition: all .3s;
    }

    .why-card:hover {
      transform: translateY(-4px);
    }

    .why-card-img {
      height: 170px;
      overflow: hidden;
      position: relative;
    }

    .why-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .4s;
    }

    .why-card:hover .why-card-img img {
      transform: scale(1.05);
    }

    .why-card-img-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(13, 40, 24, .9), transparent 60%);
    }

    .why-card-body {
      background: rgba(255, 255, 255, .05);
      border: 1px solid rgba(255, 255, 255, .08);
      border-top: none;
      padding: 20px;
      border-radius: 0 0 18px 18px;
    }

    .why-card-title {
      font-family: 'Playfair Display', serif;
      font-size: 16px;
      color: #fff;
      margin-bottom: 7px;
    }

    .why-card-desc {
      font-size: 13px;
      color: rgba(255, 255, 255, .5);
      line-height: 1.55;
    }

    /* ─────────────────────────────────────────
   PROJECTS PAGE
───────────────────────────────────────── */
    .projects-hero {
      min-height: 65vh;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding-top: 72px;
      overflow: hidden;
    }

    .projects-hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .projects-hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 60%;
    }

    .projects-hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(13, 40, 24, .82);
    }

    .projects-hero-content {
      position: relative;
      z-index: 2;
      max-width: 700px;
      margin: 0 auto;
      padding: 80px 40px;
    }

    .projects-section {
      padding: 100px 40px;
      background: var(--cream);
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
      margin-top: 48px;
    }

    .project-card {
      background: #fff;
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid rgba(0, 0, 0, .06);
      transition: all .3s;
    }

    .project-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, .1);
    }

    .project-card-img {
      height: 210px;
      overflow: hidden;
      position: relative;
    }

    .project-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .4s;
    }

    .project-card:hover .project-card-img img {
      transform: scale(1.05);
    }

    .project-status-badge {
      position: absolute;
      top: 14px;
      right: 14px;
      background: var(--gold);
      color: var(--green-dark);
      font-size: 11px;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 50px;
    }

    .project-card-body {
      padding: 22px;
    }

    .project-location {
      font-size: 12px;
      color: var(--gold);
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 7px;
    }

    .project-name {
      font-family: 'Playfair Display', serif;
      font-size: 21px;
      color: var(--green-dark);
      margin-bottom: 9px;
    }

    .project-desc {
      font-size: 13px;
      color: var(--text-light);
      line-height: 1.6;
      margin-bottom: 18px;
    }

    /* Activities grid */
    .activities-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    .activity-item {
      background: var(--beige);
      border-radius: 12px;
      padding: 16px;
      border-left: 3px solid var(--green-accent);
      font-size: 13px;
      color: var(--text-mid);
    }

    /* ─────────────────────────────────────────
   CONTACT PAGE
───────────────────────────────────────── */
    .contact-page {
      min-height: 100vh;
      padding-top: 72px;
    }

    .contact-hero {
      height: 340px;
      position: relative;
      overflow: hidden;
    }

    .contact-hero img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 50%;
    }

    .contact-hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(160deg, rgba(13, 40, 24, .88), rgba(26, 74, 46, .75));
    }

    .contact-hero-text {
      position: absolute;
      inset: 0;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      flex-direction: column;
      padding: 40px;
    }

    .contact-hero-text h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(40px, 5vw, 64px);
      font-weight: 900;
      color: #fff;
      line-height: 1.1;
    }

    .contact-hero-text p {
      font-size: 17px;
      color: rgba(255, 255, 255, .65);
      margin-top: 12px;
      max-width: 500px;
    }

    .contact-body {
      max-width: 1200px;
      margin: 0 auto;
      padding: 80px 40px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 72px;
      align-items: start;
    }

    .contact-info h2 {
      font-family: 'Playfair Display', serif;
      font-size: 32px;
      color: var(--green-dark);
      margin-bottom: 14px;
    }

    .contact-info p {
      font-size: 15px;
      color: var(--text-light);
      line-height: 1.7;
      margin-bottom: 32px;
    }

    .contact-details {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .contact-detail {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 15px 18px;
      background: var(--beige);
      border-radius: 12px;
    }

    .contact-detail-icon {
      width: 42px;
      height: 42px;
      background: var(--green-light);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }

    .contact-detail h4 {
      font-size: 13px;
      font-weight: 600;
      color: var(--green-dark);
    }

    .contact-detail p {
      font-size: 13px;
      color: var(--text-light);
      margin-bottom: 0;
    }

    .contact-map-img {
      border-radius: 16px;
      overflow: hidden;
      height: 180px;
      margin-top: 24px;
    }

    .contact-map-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .contact-form {
      background: #fff;
      border-radius: 20px;
      padding: 40px;
      border: 1px solid rgba(0, 0, 0, .06);
      box-shadow: 0 20px 40px rgba(0, 0, 0, .06);
    }

    .contact-form h2 {
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      color: var(--green-dark);
      margin-bottom: 26px;
    }

    .form-group {
      margin-bottom: 18px;
    }

    .form-group label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: var(--text-mid);
      margin-bottom: 6px;
      letter-spacing: .3px;
      text-transform: uppercase;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 12px 15px;
      border: 1.5px solid rgba(0, 0, 0, .1);
      border-radius: 9px;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      color: var(--text-dark);
      background: var(--cream);
      outline: none;
      transition: border-color .2s;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      border-color: var(--green-accent);
      background: #fff;
    }

    .form-group textarea {
      height: 110px;
      resize: none;
    }

    /* ── RESPONSIVE ── */
    @media(max-width:1100px) {

      .problem-grid,
      .tech-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .eco-grid,
      .models-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .impact-grid,
      .metrics-grid,
      .revenue-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .mission-pillars {
        grid-template-columns: repeat(2, 1fr);
      }

      .timeline {
        grid-template-columns: repeat(3, 1fr);
      }

      .timeline::before {
        display: none;
      }

      .footer-top {
        grid-template-columns: 1fr 1fr;
        gap: 32px;
      }
    }

    @media(max-width:768px) {
      .header-inner {
        padding: 0 20px;
      }

      nav {
        display: none;
      }

      .home-hero-content,
      .farmer-hero-content,
      .model-hero-content,
      .two-col,
      .learning-inner,
      .training-cards,
      .plans-grid,
      .contact-body {
        grid-template-columns: 1fr;
        gap: 40px;
      }

      .two-col.reverse {
        direction: ltr;
      }

      .hero-stats {
        gap: 20px;
      }

      .eco-grid,
      .models-grid,
      .projects-grid,
      .tech-tools-grid {
        grid-template-columns: 1fr;
      }

      .problem-grid,
      .mission-pillars,
      .csa-stats-row,
      .why-grid,
      .delivery-grid,
      .carbon-points,
      .model-benefits-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .tech-grid,
      .impact-grid,
      .metrics-grid,
      .revenue-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .journey-steps {
        flex-direction: column;
        align-items: flex-start;
      }

      .journey-arrow {
        display: none;
      }

      .model-img-strip {
        grid-template-columns: 1fr;
      }

      .activities-grid {
        grid-template-columns: 1fr;
      }
    }

    /* ── INCOME GENERATION SECTION ── */
    .income-section {
      padding: 100px 40px;
      background: linear-gradient(160deg, var(--green-dark) 0%, #0a1f12 100%);
      position: relative;
      overflow: hidden;
    }

    .income-section::before {
      content: '';
      position: absolute;
      top: -120px;
      right: -120px;
      width: 400px;
      height: 400px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(201, 150, 62, .09) 0%, transparent 70%);
      pointer-events: none;
    }

    .income-section .section-heading {
      color: #fff;
    }

    .income-section .section-tag {
      color: var(--gold-light);
    }

    .income-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-top: 56px;
    }

    .income-card {
      border-radius: 18px;
      overflow: hidden;
      background: rgba(255, 255, 255, .04);
      border: 1px solid rgba(255, 255, 255, .09);
      transition: all .3s;
      display: flex;
      flex-direction: column;
    }

    .income-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 24px 48px rgba(0, 0, 0, .4);
      border-color: rgba(201, 150, 62, .35);
    }

    /* Wide card spans full row */
    .income-card--wide {
      grid-column: 1 / -1;
      flex-direction: row;
    }

    .income-card--wide .income-card-img--wide {
      width: 340px;
      flex-shrink: 0;
      height: auto;
    }

    .income-card--wide .income-card-body--wide {
      flex: 1;
    }

    .income-card-img {
      height: 175px;
      overflow: hidden;
      position: relative;
    }

    .income-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .5s;
      opacity: .75;
    }

    .income-card:hover .income-card-img img {
      transform: scale(1.06);
      opacity: .9;
    }

    .income-card-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(10, 30, 15, .85) 0%, transparent 55%);
    }

    .income-card-num {
      position: absolute;
      bottom: 12px;
      right: 14px;
      font-family: 'Playfair Display', serif;
      font-size: 42px;
      font-weight: 700;
      color: rgba(201, 150, 62, .55);
      line-height: 1;
      letter-spacing: -1px;
    }

    .income-card-body {
      padding: 22px;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .income-card-icon {
      font-size: 26px;
      margin-bottom: 10px;
    }

    .income-card-title {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      color: #fff;
      margin-bottom: 10px;
      line-height: 1.3;
    }

    .income-card-lead {
      font-size: 13px;
      color: rgba(255, 255, 255, .62);
      line-height: 1.65;
      margin-bottom: 12px;
    }

    .income-card-lead--sub {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gold-light);
      margin-bottom: 6px;
    }

    .income-card-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 7px;
      margin-top: auto;
    }

    .income-card-list li {
      font-size: 12px;
      color: rgba(255, 255, 255, .52);
      line-height: 1.5;
      padding-left: 16px;
      position: relative;
    }

    .income-card-list li::before {
      content: '→';
      position: absolute;
      left: 0;
      color: var(--gold);
      font-size: 11px;
    }

    /* Solar card accent border */
    .income-card--solar {
      border-color: rgba(255, 200, 60, .18);
    }

    .income-card--solar .income-card-num {
      color: rgba(255, 200, 60, .6);
    }

    /* Accent card */
    .income-card--accent {
      border-color: rgba(64, 145, 108, .25);
    }

    /* Wide card extra grid */
    .income-extra-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 10px 20px;
      margin-top: 14px;
    }

    .income-extra-item {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      font-size: 13px;
      color: rgba(255, 255, 255, .6);
      line-height: 1.5;
    }

    .income-extra-icon {
      font-size: 16px;
      flex-shrink: 0;
      margin-top: 1px;
    }

    /* Stats strip */
    .income-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      margin-top: 48px;
      background: rgba(255, 255, 255, .07);
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, .08);
    }

    .income-stat {
      padding: 28px 20px;
      text-align: center;
      background: rgba(255, 255, 255, .03);
      transition: background .2s;
    }

    .income-stat:hover {
      background: rgba(201, 150, 62, .08);
    }

    .income-stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 42px;
      font-weight: 700;
      color: var(--gold-light);
      line-height: 1;
      margin-bottom: 8px;
    }

    .income-stat-label {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .42);
    }

    @media(max-width:1100px) {
      .income-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .income-card--wide {
        flex-direction: column;
      }

      .income-card--wide .income-card-img--wide {
        width: 100%;
        height: 200px;
      }

      .income-extra-grid {
        grid-template-columns: 1fr 1fr;
      }

      .income-stats {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media(max-width:700px) {
      .income-grid {
        grid-template-columns: 1fr;
      }

      .income-stats {
        grid-template-columns: 1fr 1fr;
      }
    }
  </style>
</head>

<body>

  <!-- ===== HEADER ===== -->
  <header id="main-header" style="box-shadow: rgba(0, 0, 0, 0.35) 0px 4px 24px;">
    <div class="header-inner">
      <a class="logo" onclick="showPage(&#39;home&#39;)" style="gap:0;">
        <img
          src="data:image/png;base64,"
          alt="Chedi The Organic Farm" style="height:56px;width:auto;object-fit:contain;display:block;">
      </a>
      <nav>
        <span class="nav-link" onclick="showPage(&#39;csa&#39;)">CSA</span>
        <span class="nav-link" onclick="showPage(&#39;land&#39;)">Agri-Land</span>
        <span class="nav-link" onclick="showPage(&#39;farmer&#39;)">Farmer</span>
        <div class="dropdown">
          <span class="nav-link">Model ▾</span>
          <div class="dropdown-menu">
            <span class="dropdown-item" onclick="showPage(&#39;model1&#39;)">Model 1 – Shared Farming</span>
            <span class="dropdown-item" onclick="showPage(&#39;model2&#39;)">Model 2 – Independent</span>
          </div>
        </div>
        <span class="nav-link" onclick="showPage(&#39;projects&#39;)">Projects</span>
        <span class="nav-link" onclick="showPage(&#39;about&#39;)">About Us</span>
        <span class="nav-link nav-cta btn" onclick="showPage(&#39;contact&#39;)">Contact Us</span>
      </nav>
    </div>
  </header>

  <!-- ========== HOME PAGE ========== -->
  <div class="page" id="page-home">

    <!-- HERO -->
    <section class="home-hero">
      <div class="home-hero-bg"></div>
      <div class="home-hero-content">
        <div>
          <div class="hero-badge">
            <div class="hero-dot"></div><span>Rebuilding Agriculture Since 2018</span>
          </div>
          <h1 class="hero-title">Rebuilding Agriculture<br>for the <span class="gold">Next Generation</span></h1>
          <p class="hero-sub">Health begins with what we grow. CHEDI transforms land, empowers farmers, and builds
            sustainable farming ecosystems for a healthier future.</p>
          <div class="cta-btns">
            <button class="btn btn-gold" onclick="showPage(&#39;about&#39;)">Explore Our Ecosystem</button>
            <button class="btn btn-outline" onclick="showPage(&#39;contact&#39;)">Partner With Us</button>
          </div>
          <div class="hero-stats">
            <div>
              <div class="hero-stat-num">40+</div>
              <div class="hero-stat-label">Acres of Land</div>
            </div>
            <div>
              <div class="hero-stat-num">1,200+</div>
              <div class="hero-stat-label">Active Members</div>
            </div>
            <div>
              <div class="hero-stat-num">2018</div>
              <div class="hero-stat-label">Founded</div>
            </div>
          </div>
        </div>
        <div>
          <div class="hero-img-card">
            <img src="https://images.unsplash.com/photo-1464226184884-fa280b87c399?w=1200&q=80&auto=format&fit=crop"
              alt="Organic farming" loading="lazy">
            <div class="hero-img-overlay"></div>
            <div class="hero-img-badge">
              <div class="hero-img-badge-stat">
                <div class="n">40+</div>
                <div class="l">Varieties</div>
              </div>
              <div class="hero-img-badge-stat">
                <div class="n">Zero</div>
                <div class="l">Chemicals</div>
              </div>
              <div class="hero-img-badge-stat">
                <div class="n">Lab</div>
                <div class="l">Certified</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROBLEM -->
    <section class="problem-section">
      <div class="container">
        <div class="section-header">
          <div class="section-tag">THE CHALLENGE</div>
          <h2 class="section-heading white">Modern Agriculture<br>Is Breaking Down</h2>
        </div>
        <div class="problem-grid">
          <div class="problem-card">
            <div class="problem-card-img"><img src="https://chediwebsite.s3.us-east-1.amazonaws.com/images/7581.jpg"
                alt="Soil degradation" loading="lazy"></div>
            <div class="problem-card-body">
              <div class="problem-card-title">Soil Degradation</div>
              <div class="problem-card-desc">Decades of chemical farming are reducing soil fertility and long-term
                productivity across millions of acres.</div>
            </div>
          </div>
          <div class="problem-card">
            <div class="problem-card-img"><img
                src="https://images.unsplash.com/photo-1586771107445-d3ca888129ff?w=1200&q=80&auto=format&fit=crop"
                alt="Farmer income" loading="lazy"></div>
            <div class="problem-card-body">
              <div class="problem-card-title">Farmer Income Crisis</div>
              <div class="problem-card-desc">Farmers face low income, uncertain outcomes, and limited access to
                technology and market opportunities.</div>
            </div>
          </div>
          <div class="problem-card">
            <div class="problem-card-img"><img
                src="https://images.unsplash.com/photo-1625246333195-78d9c38ad449?w=1200&q=80&auto=format&fit=crop"
                alt="Chemical farming" loading="lazy"></div>
            <div class="problem-card-body">
              <div class="problem-card-title">Chemical Farming Harm</div>
              <div class="problem-card-desc">Heavy pesticide use harms long-term health, soil ecosystems, and water
                quality for generations.</div>
            </div>
          </div>
          <div class="problem-card">
            <div class="problem-card-img"><img
                src="https://images.unsplash.com/photo-1536304993881-ff6e9eefa2a6?w=1200&q=80&auto=format&fit=crop"
                alt="Food quality" loading="lazy"></div>
            <div class="problem-card-body">
              <div class="problem-card-title">Declining Food Quality</div>
              <div class="problem-card-desc">Nutritional value in food continues to drop as industrial farming
                prioritizes yield over quality.</div>
            </div>
          </div>
        </div>
        <div class="problem-closing">
          <p>CHEDI rebuilds agriculture <span>from the ground up.</span></p>
        </div>
      </div>
    </section>

    <!-- ECOSYSTEM -->
    <section class="ecosystem-section">
      <div class="container">
        <div class="section-header">
          <div class="section-tag">OUR ECOSYSTEM</div>
          <h2 class="section-heading">One Ecosystem. Complete<br>Agricultural Transformation.</h2>
          <p class="section-sub">CHEDI connects land, farmers, technology, and sustainable systems into one scalable
            agricultural ecosystem.</p>
        </div>
        <div class="eco-grid">
          <div class="eco-card" onclick="showPage(&#39;land&#39;)">
            <div class="eco-card-img"><img src="https://chediwebsite.s3.us-east-1.amazonaws.com/images/9355.jpg"
                alt="Land" loading="lazy"></div>
            <div class="eco-card-body">
              <div class="eco-card-title">🌍 Land Restoration &amp; Development</div>
              <div class="eco-card-desc">We identify, acquire, and restore farmland using natural methods. Unused land
                becomes productive, sustainable farms.</div>
            </div>
          </div>
          <div class="eco-card" onclick="showPage(&#39;farmer&#39;)">
            <div class="eco-card-img"><img src="https://chediwebsite.s3.us-east-1.amazonaws.com/images/14786.jpg"
                alt="Farmers" loading="lazy"></div>
            <div class="eco-card-body">
              <div class="eco-card-title">👨‍🌾 Farmer Enablement Programs</div>
              <div class="eco-card-desc">Training, tools, technology, and market access for farmers at every level —
                reducing risk and increasing income.</div>
            </div>
          </div>
          <div class="eco-card" onclick="showPage(&#39;csa&#39;)">
            <div class="eco-card-img"><img
                src="https://images.unsplash.com/photo-1540420773420-3366772f4999?w=1200&q=80&auto=format&fit=crop"
                alt="CSA" loading="lazy"></div>
            <div class="eco-card-body">
              <div class="eco-card-title">🧺 CSA Community Agriculture</div>
              <div class="eco-card-desc">A subscription farm model delivering pesticide-free vegetables to 1,200+
                families from dedicated certified plots.</div>
            </div>
          </div>
          <div class="eco-card">
            <div class="eco-card-img"><img
                src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1200&q=80&auto=format&fit=crop"
                alt="Technology" loading="lazy"></div>
            <div class="eco-card-body">
              <div class="eco-card-title">🤖 Smart Farming Technology</div>
              <div class="eco-card-desc">AI, IoT, drone monitoring, and predictive analytics integrated for maximum
                efficiency and yield quality.</div>
            </div>
          </div>
          <div class="eco-card" onclick="showPage(&#39;model1&#39;)">
            <div class="eco-card-img"><img
                src="https://images.unsplash.com/photo-1574323347407-f5e1ad6d020b?w=1200&q=80&auto=format&fit=crop"
                alt="Model 1" loading="lazy"></div>
            <div class="eco-card-body">
              <div class="eco-card-title">🤝 Shared Farming Model</div>
              <div class="eco-card-desc">We provide land and full support. Farmers focus on cultivation. Final income is
                shared fairly and transparently.</div>
            </div>
          </div>
          <div class="eco-card" onclick="showPage(&#39;model2&#39;)">
            <div class="eco-card-img"><img src="https://chediwebsite.s3.us-east-1.amazonaws.com/images/4881.jpg"
                alt="Model 2" loading="lazy"></div>
            <div class="eco-card-body">
              <div class="eco-card-title">🚜 Independent Farming Model</div>
              <div class="eco-card-desc">For experienced farmers who want full control. We provide land, guidance, and
                assured buyback of produce.</div>
            </div>
          </div>
        </div>
        <div style="text-align:center;margin-top:48px;"><button class="btn btn-green"
            onclick="showPage(&#39;about&#39;)">Explore the Full Ecosystem →</button></div>
      </div>
    </section>

    <!-- LAND TO HEALTH -->
    <section class="story-section">
      <div class="container">
        <div class="two-col">
          <div class="story-img">
            <img src="https://chediwebsite.s3.us-east-1.amazonaws.com/images/8743.jpg" alt="Organic farm"
              loading="lazy">
            <div
              style="position:absolute;inset:0;background:linear-gradient(to top,rgba(13,40,24,.75) 0%,transparent 50%);border-radius:20px;">
            </div>
            <div class="story-img-badge">
              <h4>Zero Chemicals</h4>
              <p>Lab-tested every harvest</p>
            </div>
          </div>
          <div>
            <div class="section-tag">LAND TO HEALTH</div>
            <h2 class="section-heading">Better Land Creates<br>Better Food</h2>
            <p class="section-sub" style="margin-top:14px;">Healthy soil produces nutrient-rich crops. Better crops
              improve human health. This is how we fight the future of disease through agriculture.</p>
            <div class="story-stats">
              <div class="stat-item">
                <div class="stat-num">↓ 90%</div>
                <div class="stat-label">Chemical Reduction</div>
              </div>
              <div class="stat-item">
                <div class="stat-num">↑ 40%</div>
                <div class="stat-label">Soil Fertility Gain</div>
              </div>
              <div class="stat-item">
                <div class="stat-num">200+</div>
                <div class="stat-label">Lab Tests Per Batch</div>
              </div>
              <div class="stat-item">
                <div class="stat-num">40+</div>
                <div class="stat-label">Crop Varieties</div>
              </div>
            </div>
            <button class="btn btn-gold" style="margin-top:28px;" onclick="showPage(&#39;csa&#39;)">Explore CSA
              Program</button>
          </div>
        </div>
      </div>
    </section>

    <!-- FARMER -->
    <section class="farmer-section">
      <div class="container">
        <div class="two-col">
          <div>
            <div class="section-tag">FARMER FIRST</div>
            <h2 class="section-heading white">Built Around<br>Farmers</h2>
            <p class="section-sub white" style="margin-top:14px;">We support farmers with land, tools, training, and
              technology to increase income and reduce risk at every stage of farming.</p>
            <div class="farmer-features">
              <div class="farmer-feature">
                <div class="farmer-feature-icon">📚</div>
                <div>
                  <div class="farmer-feature-title">Smart Training Programs</div>
                  <div class="farmer-feature-desc">Modern organic techniques, water-saving methods, soil revival, and
                    pest management.</div>
                </div>
              </div>
              <div class="farmer-feature">
                <div class="farmer-feature-icon">📱</div>
                <div>
                  <div class="farmer-feature-title">Technology Access</div>
                  <div class="farmer-feature-desc">AI insights, IoT monitoring, drone analytics, and digital farming
                    tools at your fingertips.</div>
                </div>
              </div>
              <div class="farmer-feature">
                <div class="farmer-feature-icon">📈</div>
                <div>
                  <div class="farmer-feature-title">Better Market Opportunities</div>
                  <div class="farmer-feature-desc">Assured buyback, market price insights, and direct access to premium
                    buyers and networks.</div>
                </div>
              </div>
              <div class="farmer-feature">
                <div class="farmer-feature-icon">🛡️</div>
                <div>
                  <div class="farmer-feature-title">Risk Reduction Systems</div>
                  <div class="farmer-feature-desc">Structured partnerships that minimize financial risk and guarantee
                    fair income sharing.</div>
                </div>
              </div>
            </div>
            <button class="btn btn-gold" style="margin-top:28px;" onclick="showPage(&#39;farmer&#39;)">Explore Farmer
              Programs</button>
          </div>
          <div class="farmer-img">
            <img src="https://chediwebsite.s3.us-east-1.amazonaws.com/images/2148776818.jpg" alt="Farmers working"
              loading="lazy">
          </div>
        </div>
      </div>
    </section>

    <!-- MODELS PREVIEW -->
