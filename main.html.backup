  <!-- ========== CSA PAGE ========== -->
  <div class="page active" id="page-csa">

    <style>
      /* ── CSA EXTENDED STYLES ── */

      /* Welcome/Token Banner */
      .csa-token-banner {
        background: linear-gradient(135deg, #0d2818 0%, #1a4a2e 50%, #c9963e 100%);
        padding: 0;
        position: relative;
        overflow: hidden;
      }

      .csa-token-inner {
        max-width: 1400px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 420px;
        align-items: stretch;
      }

      .csa-token-left {
        padding: 60px 52px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        z-index: 2;
      }

      .csa-token-tag {
        font-size: 40px;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold-light);
        margin-bottom: 14px;
        font-weight: 600;
      }

      .csa-token-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(28px, 3.5vw, 46px);
        font-weight: 900;
        color: #fff;
        line-height: 1.15;
        margin-bottom: 16px;
      }

      .csa-token-title span {
        color: var(--gold-light);
        font-style: italic;
      }

      .csa-token-desc {
        font-size: 16px;
        color: rgba(255, 255, 255, .68);
        line-height: 1.7;
        margin-bottom: 28px;
        max-width: 420px;
      }

      .csa-token-checks {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .csa-token-check {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 14px;
        color: rgba(255, 255, 255, .82);
      }

      .csa-token-check::before {
        content: '✓';
        width: 22px;
        height: 22px;
        background: var(--gold);
        color: var(--green-dark);
        border-radius: 50%;
        font-size: 12px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .csa-token-right {
        position: relative;
        overflow: hidden;
        min-height: 380px;
      }

      .csa-token-right img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .csa-token-right::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, rgba(13, 40, 24, .7) 0%, transparent 60%);
      }

      .csa-basket-badge {
        position: absolute;
        bottom: 28px;
        left: 28px;
        z-index: 2;
        background: rgba(255, 255, 255, .2);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, .2);
        border-radius: 14px;
        padding: 16px 20px;
      }

      .csa-basket-badge h4 {
        font-family: 'Playfair Display', serif;
        font-size: 20px;
        color: #b8860b;
        ;
        text-align: center;
      }

      .csa-basket-badge p {
        font-size: 20px;
        color: rgba(90, 254, 50, 0.65);
        margin-top: 3px;
      }

      /* Membership Steps */
      .membership-steps-section {
        padding: 100px 40px;
        background: var(--cream);
      }

      .steps-intro {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 72px;
        align-items: center;
        margin-bottom: 72px;
      }

      .steps-intro-img {
        border-radius: 20px;
        overflow: hidden;
        height: 460px;
        box-shadow: 0 24px 60px rgba(0, 0, 0, .13);
      }

      .steps-intro-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .steps-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-top: 56px;
      }

      .step-card {
        background: #fff;
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid rgba(0, 0, 0, .06);
        transition: all .3s;
        text-align: center;
      }

      .step-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 16px 36px rgba(0, 0, 0, .1);
      }

      .step-card-img {
        height: 160px;
        overflow: hidden;
        position: relative;
      }

      .step-card-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform .4s;
      }

      .step-card:hover .step-card-img img {
        transform: scale(1.06);
      }

      .step-num-circle {
        position: absolute;
        top: 14px;
        left: 14px;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: var(--gold);
        color: var(--green-dark);
        font-family: 'Playfair Display', serif;
        font-size: 16px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 12px rgba(201, 150, 62, .5);
      }

      .step-card-body {
        padding: 18px 16px 22px;
      }

      .step-card-label {
        font-size: 10px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 6px;
      }

      .step-card-title {
        font-family: 'Playfair Display', serif;
        font-size: 16px;
        color: var(--green-dark);
        margin-bottom: 8px;
      }

      .step-card-desc {
        font-size: 12px;
        color: var(--text-light);
        line-height: 1.55;
      }

      /* Aerial Farm / Plot Section */
      .plot-section {
        padding: 0;
        position: relative;
        overflow: hidden;
      }

      .plot-bg {
        height: 520px;
        position: relative;
      }

      .plot-bg img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 40%;
      }

      .plot-bg-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(13, 40, 24, .6) 0%, rgba(13, 40, 24, .85) 100%);
      }

      .plot-content {
        position: absolute;
        inset: 0;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 40px;
      }

      .plot-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(32px, 4vw, 56px);
        font-weight: 900;
        color: #fff;
        margin-bottom: 12px;
      }

      .plot-sub {
        font-size: 17px;
        color: rgba(255, 255, 255, .68);
        max-width: 560px;
      }

      .plot-cards-strip {
        background: var(--beige);
        padding: 48px 40px;
        max-width: 1400px;
        margin: 0 auto;
      }

      .plot-benefits-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
      }

      .plot-benefit-card {
        background: #fff;
        border-radius: 16px;
        padding: 26px 22px;
        border: 1px solid rgba(0, 0, 0, .06);
        transition: all .25s;
      }

      .plot-benefit-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 28px rgba(0, 0, 0, .08);
      }

      .plot-benefit-title {
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        color: var(--green-dark);
        margin-bottom: 10px;
      }

      .plot-benefit-desc {
        font-size: 13px;
        color: var(--text-light);
        line-height: 1.6;
        margin-bottom: 14px;
      }

      .plot-checklist {
        display: flex;
        flex-direction: column;
        gap: 7px;
      }

      .plot-check {
        display: flex;
        align-items: center;
        gap: 9px;
        font-size: 13px;
        color: var(--text-mid);
      }

      .plot-check::before {
        content: '✓';
        color: var(--green-accent);
        font-weight: 700;
        font-size: 12px;
      }

      /* Weekly Basket */
      .basket-section {
        padding: 100px 40px;
        background: var(--green-dark);
        position: relative;
        overflow: hidden;
      }

      .basket-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
      }

      .basket-intro {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 72px;
        align-items: center;
        margin-bottom: 64px;
      }

      .basket-intro-img {
        border-radius: 20px;
        overflow: hidden;
        height: 440px;
        box-shadow: 0 24px 60px rgba(0, 0, 0, .5);
      }

      .basket-intro-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .weekly-staples-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
      }

      .veg-card {
        background: rgba(255, 255, 255, .06);
        border: 1px solid rgba(255, 255, 255, .1);
        border-radius: 16px;
        overflow: hidden;
        transition: all .3s;
      }

      .veg-card:hover {
        background: rgba(255, 255, 255, .1);
        border-color: rgba(201, 150, 62, .35);
        transform: translateY(-3px);
      }

      .veg-card-img {
        height: 100px;
        overflow: hidden;
      }

      .veg-card-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform .4s;
      }

      .veg-card:hover .veg-card-img img {
        transform: scale(1.08);
      }

      .veg-card-body {
        padding: 12px 14px;
      }

      .veg-name {
        font-size: 14px;
        font-weight: 600;
        color: #fff;
        margin-bottom: 4px;
      }

      .veg-share {
        font-size: 11px;
        color: rgba(255, 255, 255, .48);
      }

      .veg-share span {
        color: var(--gold-light);
        font-weight: 600;
      }

      .seasonal-note {
        background: rgba(255, 255, 255, .04);
        border: 1px solid rgba(255, 255, 255, .08);
        border-radius: 12px;
        padding: 18px 22px;
        margin-top: 32px;
        font-size: 13px;
        color: rgba(255, 255, 255, .5);
        line-height: 1.6;
      }

      .seasonal-note strong {
        color: rgba(255, 255, 255, .72);
      }

      /* Seasonal Carousel */
      .seasonal-section {
        padding: 80px 40px;
        background: var(--beige);
      }

      .seasonal-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-top: 48px;
      }

      .seasonal-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(0, 0, 0, .06);
        transition: all .3s;
      }

      .seasonal-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 14px 32px rgba(0, 0, 0, .1);
      }

      .seasonal-card-img {
        height: 130px;
        overflow: hidden;
      }

      .seasonal-card-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform .4s;
      }

      .seasonal-card:hover .seasonal-card-img img {
        transform: scale(1.06);
      }

      .seasonal-card-body {
        padding: 14px 16px;
      }

      .seasonal-veg-name {
        font-size: 14px;
        font-weight: 600;
        color: var(--green-dark);
        margin-bottom: 3px;
      }

      .seasonal-veg-qty {
        font-size: 12px;
        color: var(--gold);
        font-weight: 600;
      }

      /* App Download Section */
      .app-section {
        padding: 100px 40px;
        background: var(--cream);
      }

      .app-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
      }

      .app-img-wrapper {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        height: 520px;
        box-shadow: 0 32px 80px rgba(0, 0, 0, .15);
      }

      .app-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .app-img-wrapper::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(13, 40, 24, .65) 0%, transparent 55%);
      }

      .app-badge-strip {
        position: absolute;
        bottom: 24px;
        left: 24px;
        right: 24px;
        z-index: 2;
        background: rgba(255, 255, 255, .12);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, .2);
        border-radius: 14px;
        padding: 18px 20px;
      }

      .app-badge-strip h4 {
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        color: var(--gold-light);
        margin-bottom: 6px;
      }

      .app-badge-strip p {
        font-size: 12px;
        color: rgba(255, 255, 255, .65);
      }

      .app-content {}

      .app-steps {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-top: 28px;
      }

      .app-step {
        display: flex;
        gap: 16px;
        align-items: flex-start;
        background: var(--beige);
        border-radius: 14px;
        padding: 18px 20px;
        border-left: 3px solid var(--green-accent);
        transition: all .25s;
      }

      .app-step:hover {
        border-left-color: var(--gold);
        transform: translateX(4px);
      }

      .app-step-num {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, var(--green-mid), var(--green-accent));
        color: #fff;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .app-step-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--green-dark);
        margin-bottom: 3px;
      }

      .app-step-desc {
        font-size: 13px;
        color: var(--text-light);
        line-height: 1.5;
      }

      .app-dl-btns {
        display: flex;
        gap: 12px;
        margin-top: 28px;
        flex-wrap: wrap;
      }

      .app-dl-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: var(--green-dark);
        color: #fff;
        border-radius: 12px;
        padding: 12px 20px;
        cursor: pointer;
        transition: all .25s;
        border: 1px solid rgba(255, 255, 255, .08);
      }

      .app-dl-btn:hover {
        background: var(--green-mid);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(13, 40, 24, .3);
      }

      .app-dl-btn .dl-icon {
        font-size: 22px;
      }

      .app-dl-btn-text .dl-sub {
        font-size: 10px;
        color: rgba(255, 255, 255, .5);
        letter-spacing: .5px;
      }

      .app-dl-btn-text .dl-main {
        font-size: 14px;
        font-weight: 600;
        color: #fff;
      }

      /* Membership Fee */
      .membership-fee-section {
        padding: 80px 40px;
        background: var(--beige-dark);
      }

      .fee-card {
        background: #fff;
        border-radius: 24px;
        overflow: hidden;
        display: grid;
        grid-template-columns: 1fr 1fr;
        box-shadow: 0 20px 60px rgba(0, 0, 0, .1);
        border: 1px solid rgba(0, 0, 0, .06);
      }

      .fee-left {
        padding: 52px;
      }

      .fee-right {
        position: relative;
        overflow: hidden;
        min-height: 360px;
      }

      .fee-right img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .fee-right::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, rgba(13, 40, 24, .5) 0%, transparent 60%);
      }

      .fee-tag {
        font-size: 11px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 14px;
        font-weight: 600;
      }

      .fee-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(28px, 3vw, 42px);
        color: var(--green-dark);
        line-height: 1.2;
        margin-bottom: 14px;
      }

      .fee-amount {
        font-family: 'Playfair Display', serif;
        font-size: 56px;
        font-weight: 900;
        color: var(--green-dark);
        line-height: 1;
        margin-bottom: 6px;
      }

      .fee-amount span {
        font-size: 24px;
        color: var(--gold);
      }

      .fee-one-time {
        font-size: 14px;
        color: var(--text-light);
        margin-bottom: 24px;
      }

      .fee-includes {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 28px;
      }

      .fee-include {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        color: var(--text-mid);
      }

      .fee-include::before {
        content: '✓';
        width: 20px;
        height: 20px;
        background: var(--green-accent);
        color: #fff;
        border-radius: 50%;
        font-size: 10px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      /* Coming Soon */
      .coming-soon-section {
        padding: 80px 40px;
        background: var(--cream);
      }

      .cs-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
        margin-top: 48px;
      }

      .cs-card {
        border-radius: 20px;
        overflow: hidden;
        position: relative;
        height: 280px;
        transition: all .3s;
      }

      .cs-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, .15);
      }

      .cs-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .cs-card-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(13, 40, 24, .9) 0%, rgba(13, 40, 24, .4) 60%, transparent 100%);
      }

      .cs-card-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 28px 30px;
      }

      .cs-card-tag {
        font-size: 11px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 8px;
      }

      .cs-card-title {
        font-family: 'Playfair Display', serif;
        font-size: 26px;
        color: #fff;
        font-weight: 700;
        margin-bottom: 8px;
      }

      .cs-card-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(201, 150, 62, .25);
        border: 1px solid rgba(201, 150, 62, .4);
        border-radius: 50px;
        padding: 5px 14px;
        font-size: 12px;
        color: var(--gold-light);
        font-weight: 600;
      }

      /* Responsive CSA */
      @media(max-width:1024px) {

        .csa-token-inner,
        .steps-intro,
        .basket-intro,
        .app-inner,
        .fee-card {
          grid-template-columns: 1fr;
        }

        .steps-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .weekly-staples-grid {
          grid-template-columns: repeat(3, 1fr);
        }

        .seasonal-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .plot-benefits-grid {
          grid-template-columns: 1fr;
        }

        .csa-token-right {
          min-height: 280px;
        }

        .fee-right {
          min-height: 240px;
        }
      }

      @media(max-width:768px) {

        .steps-grid,
        .weekly-staples-grid,
        .seasonal-grid,
        .cs-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .csa-token-left {
          padding: 36px 28px;
        }

        .fee-left {
          padding: 32px;
        }
      }

      /* ── LONGEVITY BUTTON ── */
      .btn-longevity {
        background: linear-gradient(135deg, #1a0533 0%, #3d0f6e 40%, #6b21a8 100%);
        color: #e8d5ff;
        border: 1.5px solid rgba(168, 85, 247, 0.5);
        position: relative;
        overflow: hidden;
        font-size: 14px;
        letter-spacing: 1px;
        box-shadow: 0 0 24px rgba(139, 92, 246, 0.35);
        animation: longevityPulse 3s ease-in-out infinite;
      }

      .btn-longevity:hover {
        transform: translateY(-3px);
        box-shadow: 0 0 40px rgba(139, 92, 246, 0.7), 0 8px 32px rgba(0, 0, 0, 0.4);
        background: linear-gradient(135deg, #2d0a5c 0%, #5b1aab 40%, #8b3cf7 100%);
        color: #fff;
      }

      .longevity-btn-icon {
        font-size: 16px;
        animation: spin 4s linear infinite;
        display: inline-block;
      }

      @keyframes longevityPulse {

        0%,
        100% {
          box-shadow: 0 0 24px rgba(139, 92, 246, 0.35);
        }

        50% {
          box-shadow: 0 0 48px rgba(139, 92, 246, 0.7), 0 0 80px rgba(168, 85, 247, 0.2);
        }
      }

      @keyframes spin {
        from {
          transform: rotate(0deg);
        }

        to {
          transform: rotate(360deg);
        }
      }

      /* ── LONGEVITY MODAL ── */
      #longevityModal {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(5, 2, 15, 0.92);
        backdrop-filter: blur(12px);
        overflow-y: auto;
      }

      #longevityModal.open {
        display: block;
        animation: modalFadeIn 0.4s ease;
      }

      @keyframes modalFadeIn {
        from {
          opacity: 0;
        }

        to {
          opacity: 1;
        }
      }

      .lng-close-btn {
        position: sticky;
        top: 20px;
        float: right;
        margin-right: 20px;
        z-index: 10;
        width: 44px;
        height: 44px;
        background: rgba(139, 92, 246, 0.2);
        border: 1px solid rgba(168, 85, 247, 0.4);
        border-radius: 50%;
        color: #e8d5ff;
        font-size: 22px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
      }

      .lng-close-btn:hover {
        background: rgba(139, 92, 246, 0.5);
        transform: rotate(90deg);
      }

      /* Modal Hero */
      .lng-hero {
        min-height: 100vh;
        background: linear-gradient(160deg, #030108 0%, #0d0222 40%, #1a0440 70%, #0f0225 100%);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 80px 40px;
        overflow: hidden;
      }

      .lng-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 80% 60% at 50% 30%, rgba(139, 92, 246, 0.15) 0%, transparent 70%),
          radial-gradient(ellipse 50% 40% at 80% 80%, rgba(59, 130, 246, 0.08) 0%, transparent 60%);
      }

      .lng-hero-particles {
        position: absolute;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
      }

      .lng-particle {
        position: absolute;
        border-radius: 50%;
        background: rgba(168, 85, 247, 0.4);
        animation: floatParticle linear infinite;
      }

      @keyframes floatParticle {
        0% {
          transform: translateY(100vh) scale(0);
          opacity: 0;
        }

        10% {
          opacity: 1;
        }

        90% {
          opacity: 1;
        }

        100% {
          transform: translateY(-10vh) scale(1);
          opacity: 0;
        }
      }

      .lng-hero-content {
        position: relative;
        z-index: 2;
        max-width: 900px;
        margin: 0 auto;
      }

      .lng-hero-tag {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(139, 92, 246, 0.12);
        border: 1px solid rgba(168, 85, 247, 0.3);
        border-radius: 50px;
        padding: 8px 22px;
        font-size: 11px;
        letter-spacing: 4px;
        color: #c4b5fd;
        text-transform: uppercase;
        margin-bottom: 32px;
      }

      .lng-hero-tag::before,
      .lng-hero-tag::after {
        content: '✦';
        font-size: 8px;
        color: #a78bfa;
      }

      .lng-hero-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(44px, 7vw, 96px);
        font-weight: 900;
        color: #fff;
        line-height: 1.0;
        margin-bottom: 16px;
        letter-spacing: -2px;
      }

      .lng-hero-title .purple {
        color: #c084fc;
      }

      .lng-hero-title .gold {
        color: #e8b96a;
      }

      .lng-hero-subtitle {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(18px, 2.5vw, 28px);
        color: #a78bfa;
        font-style: italic;
        margin-bottom: 40px;
      }

      .lng-hero-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        justify-content: center;
        margin-bottom: 48px;
      }

      .lng-pill {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(168, 85, 247, 0.2);
        border-radius: 50px;
        padding: 10px 22px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        cursor: default;
        transition: all 0.3s;
      }

      .lng-pill:hover {
        background: rgba(139, 92, 246, 0.12);
        border-color: rgba(168, 85, 247, 0.5);
        transform: translateY(-3px);
      }

      .lng-pill-title {
        font-size: 13px;
        font-weight: 600;
        color: #e8d5ff;
      }

      .lng-pill-sub {
        font-size: 10px;
        color: rgba(168, 85, 247, 0.7);
        letter-spacing: 1px;
      }

      .lng-hero-img-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        max-width: 800px;
        margin: 0 auto;
      }

      .lng-hero-img-card {
        border-radius: 16px;
        overflow: hidden;
        height: 200px;
        position: relative;
        border: 1px solid rgba(168, 85, 247, 0.2);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
      }

      .lng-hero-img-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .lng-hero-img-card::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(13, 2, 34, 0.7) 0%, transparent 60%);
      }

      .lng-hero-img-label {
        position: absolute;
        bottom: 12px;
        left: 0;
        right: 0;
        text-align: center;
        font-size: 12px;
        color: #c4b5fd;
        z-index: 2;
        letter-spacing: 1px;
      }

      /* Section generic */
      .lng-section {
        padding: 96px 40px;
        position: relative;
      }

      .lng-section-inner {
        max-width: 1200px;
        margin: 0 auto;
      }

      .lng-section-tag {
        font-size: 10px;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: #a78bfa;
        margin-bottom: 12px;
        display: block;
      }

      .lng-section-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(28px, 4vw, 52px);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 10px;
      }

      .lng-section-sub {
        font-size: 16px;
        line-height: 1.72;
        margin-bottom: 48px;
        opacity: 0.7;
      }

      /* We Care Section */
      .lng-care {
        background: linear-gradient(135deg, #05020f 0%, #0e0327 100%);
        color: #fff;
      }

      .lng-care-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 20px;
        margin-top: 48px;
      }

      .lng-care-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(168, 85, 247, 0.15);
        border-radius: 20px;
        padding: 32px 20px;
        text-align: center;
        transition: all 0.4s;
        position: relative;
        overflow: hidden;
      }

      .lng-care-card::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(ellipse at center, rgba(139, 92, 246, 0.08) 0%, transparent 60%);
        opacity: 0;
        transition: opacity 0.4s;
      }

      .lng-care-card:hover {
        transform: translateY(-8px);
        border-color: rgba(168, 85, 247, 0.5);
      }

      .lng-care-card:hover::before {
        opacity: 1;
      }

      .lng-care-img {
        width: 100%;
        height: 140px;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 18px;
      }

      .lng-care-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .lng-care-icon {
        font-size: 36px;
        margin-bottom: 14px;
      }

      .lng-care-name {
        font-family: 'Playfair Display', serif;
        font-size: 20px;
        color: #e8d5ff;
        font-weight: 700;
        margin-bottom: 8px;
      }

      .lng-care-desc {
        font-size: 13px;
        color: rgba(168, 85, 247, 0.7);
        line-height: 1.5;
      }

      /* Holistic Solutions */
      .lng-holistic {
        background: linear-gradient(160deg, #0a0220 0%, #1a0440 50%, #0d0228 100%);
        color: #fff;
      }

      .lng-holistic-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
        margin-top: 48px;
      }

      .lng-holistic-card {
        border-radius: 24px;
        overflow: hidden;
        position: relative;
        height: 360px;
        transition: all 0.4s;
        border: 1px solid rgba(168, 85, 247, 0.2);
      }

      .lng-holistic-card:hover {
        transform: translateY(-10px) scale(1.02);
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.6), 0 0 40px rgba(139, 92, 246, 0.2);
      }

      .lng-holistic-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .lng-holistic-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(8, 1, 22, 0.92) 0%, rgba(20, 4, 52, 0.5) 50%, transparent 100%);
      }

      .lng-holistic-body {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 28px 24px;
      }

      .lng-holistic-icon {
        font-size: 32px;
        margin-bottom: 10px;
      }

      .lng-holistic-title {
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        color: #fff;
        font-weight: 700;
        margin-bottom: 6px;
      }

      .lng-holistic-sub {
        font-size: 13px;
        color: #a78bfa;
        font-style: italic;
      }

      /* Nutrition Section */
      .lng-nutrition {
        background: linear-gradient(135deg, #020b04 0%, #041a0c 50%, #071d0e 100%);
        color: #fff;
      }

      .lng-nutrition-hero {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 64px;
        align-items: center;
        margin-bottom: 80px;
      }

      .lng-nutrition-quote {
        font-family: 'Playfair Display', serif;
        font-size: clamp(28px, 3.5vw, 46px);
        font-weight: 800;
        line-height: 1.15;
        color: #fff;
        margin-bottom: 24px;
      }

      .lng-nutrition-quote .highlight {
        color: #4ade80;
      }

      .lng-nutrition-img {
        border-radius: 24px;
        overflow: hidden;
        height: 480px;
        position: relative;
        border: 1px solid rgba(74, 222, 128, 0.2);
      }

      .lng-nutrition-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .lng-nutrition-img::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(4, 26, 12, 0.4) 0%, transparent 100%);
      }

      /* Modern Lifestyle / Impact / Solution */
      .lng-pillars {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
        margin-bottom: 64px;
      }

      .lng-pillar-card {
        border-radius: 20px;
        overflow: hidden;
        position: relative;
      }

      .lng-pillar-img {
        height: 220px;
        position: relative;
      }

      .lng-pillar-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .lng-pillar-img::after {
        content: '';
        position: absolute;
        inset: 0;
        background: inherit;
      }

      .lng-pillar-body {
        padding: 28px;
      }

      .lng-pillar-card.lifestyle {
        background: rgba(220, 38, 38, 0.08);
        border: 1px solid rgba(220, 38, 38, 0.2);
      }

      .lng-pillar-card.lifestyle .lng-pillar-img::after {
        background: linear-gradient(to top, rgba(69, 10, 10, 0.8), transparent);
      }

      .lng-pillar-card.affects {
        background: rgba(59, 130, 246, 0.08);
        border: 1px solid rgba(59, 130, 246, 0.2);
      }

      .lng-pillar-card.affects .lng-pillar-img::after {
        background: linear-gradient(to top, rgba(8, 23, 69, 0.8), transparent);
      }

      .lng-pillar-card.solution {
        background: rgba(74, 222, 128, 0.08);
        border: 1px solid rgba(74, 222, 128, 0.2);
      }

      .lng-pillar-card.solution .lng-pillar-img::after {
        background: linear-gradient(to top, rgba(5, 46, 22, 0.8), transparent);
      }

      .lng-pillar-title {
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 16px;
      }

      .lng-pillar-card.lifestyle .lng-pillar-title {
        color: #fca5a5;
      }

      .lng-pillar-card.affects .lng-pillar-title {
        color: #93c5fd;
      }

      .lng-pillar-card.solution .lng-pillar-title {
        color: #86efac;
      }

      .lng-pillar-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .lng-pillar-list li {
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
        color: rgba(255, 255, 255, 0.75);
        padding: 8px 12px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.03);
      }

      .lng-pillar-card.lifestyle li::before {
        content: '●';
        color: #f87171;
        font-size: 8px;
      }

      .lng-pillar-card.affects li::before {
        content: '●';
        color: #60a5fa;
        font-size: 8px;
      }

      .lng-pillar-card.solution li::before {
        content: '●';
        color: #4ade80;
        font-size: 8px;
      }

      /* Impact by audience */
      .lng-impact-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        margin-top: 56px;
      }

      .lng-impact-card {
        border-radius: 20px;
        overflow: hidden;
        position: relative;
      }

      .lng-impact-img {
        height: 260px;
      }

      .lng-impact-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .lng-impact-body {
        padding: 28px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-top: none;
      }

      .lng-impact-label {
        font-size: 10px;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #4ade80;
        margin-bottom: 8px;
      }

      .lng-impact-name {
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        color: #fff;
        font-weight: 700;
        margin-bottom: 14px;
      }

      .lng-impact-items {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .lng-impact-item {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.65);
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .lng-impact-item::before {
        content: '→';
        color: #4ade80;
        font-weight: 700;
      }

      /* Deficiency Tiers */
      .lng-deficiency {
        background: linear-gradient(160deg, #020813 0%, #050f26 60%, #020813 100%);
        color: #fff;
      }

      .lng-tiers {
        display: flex;
        flex-direction: column;
        gap: 64px;
        margin-top: 56px;
      }

      .lng-tier-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 32px;
      }

      .lng-tier-badge {
        background: linear-gradient(135deg, #7c3aed, #4f46e5);
        color: #fff;
        font-size: 11px;
        letter-spacing: 3px;
        text-transform: uppercase;
        padding: 8px 20px;
        border-radius: 50px;
        white-space: nowrap;
      }

      .lng-tier-badge.t1 {
        background: linear-gradient(135deg, #dc2626, #9f1239);
      }

      .lng-tier-badge.t2 {
        background: linear-gradient(135deg, #d97706, #b45309);
      }

      .lng-tier-badge.t3 {
        background: linear-gradient(135deg, #059669, #065f46);
      }

      .lng-tier-badge.t4 {
        background: linear-gradient(135deg, #7c3aed, #4f46e5);
      }

      .lng-tier-title {
        font-family: 'Playfair Display', serif;
        font-size: 26px;
        font-weight: 700;
        color: #e8d5ff;
      }

      .lng-tier-line {
        flex: 1;
        height: 1px;
        background: rgba(255, 255, 255, 0.08);
      }

      .lng-conditions-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
      }

      .lng-conditions-grid.two {
        grid-template-columns: repeat(2, 1fr);
      }

      .lng-conditions-grid.three {
        grid-template-columns: repeat(3, 1fr);
      }

      .lng-conditions-grid.four {
        grid-template-columns: repeat(4, 1fr);
      }

      .lng-condition-card {
        border-radius: 16px;
        overflow: hidden;
        position: relative;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.07);
        transition: all 0.35s;
      }

      .lng-condition-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5);
        border-color: rgba(168, 85, 247, 0.3);
      }

      .lng-condition-img {
        height: 180px;
        position: relative;
      }

      .lng-condition-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .lng-condition-img::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(5, 2, 15, 0.85) 0%, transparent 60%);
      }

      .lng-condition-num {
        position: absolute;
        top: 12px;
        left: 12px;
        width: 32px;
        height: 32px;
        background: rgba(139, 92, 246, 0.8);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        color: #fff;
        z-index: 2;
      }

      .lng-condition-body {
        padding: 20px;
      }

      .lng-condition-title {
        font-family: 'Playfair Display', serif;
        font-size: 17px;
        color: #e8d5ff;
        font-weight: 700;
        margin-bottom: 12px;
      }

      .lng-condition-row {
        display: flex;
        gap: 6px;
        margin-bottom: 6px;
      }

      .lng-condition-key {
        font-size: 10px;
        letter-spacing: 2px;
        color: #a78bfa;
        text-transform: uppercase;
        white-space: nowrap;
        padding-top: 1px;
      }

      .lng-condition-val {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.5;
      }

      .lng-condition-eat {
        margin-top: 12px;
        padding: 10px 14px;
        background: rgba(74, 222, 128, 0.07);
        border: 1px solid rgba(74, 222, 128, 0.15);
        border-radius: 8px;
        font-size: 13px;
        color: #86efac;
      }

      .lng-condition-eat-label {
        font-size: 10px;
        letter-spacing: 2px;
        color: rgba(74, 222, 128, 0.6);
        margin-bottom: 4px;
      }

      /* Closing banner */
      .lng-closing {
        background: linear-gradient(135deg, #030108 0%, #0d0222 50%, #030108 100%);
        text-align: center;
        padding: 100px 40px;
        position: relative;
        overflow: hidden;
      }

      .lng-closing::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(139, 92, 246, 0.12) 0%, transparent 70%);
      }

      .lng-closing-content {
        position: relative;
        z-index: 2;
        max-width: 760px;
        margin: 0 auto;
      }

      .lng-closing-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(28px, 4vw, 52px);
        font-weight: 900;
        color: #fff;
        margin-bottom: 16px;
        line-height: 1.15;
      }

      .lng-closing-sub {
        font-size: 17px;
        color: rgba(168, 85, 247, 0.8);
        line-height: 1.7;
        margin-bottom: 12px;
      }

      .lng-closing-note {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.35);
        margin-top: 40px;
        padding: 16px 24px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        display: inline-block;
      }

      @media(max-width: 900px) {
        .lng-care-grid {
          grid-template-columns: repeat(3, 1fr);
        }

        .lng-holistic-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .lng-nutrition-hero {
          grid-template-columns: 1fr;
        }

        .lng-pillars {
          grid-template-columns: 1fr;
        }

        .lng-impact-row {
          grid-template-columns: 1fr;
        }

        .lng-conditions-grid,
        .lng-conditions-grid.two,
        .lng-conditions-grid.three,
        .lng-conditions-grid.four {
          grid-template-columns: repeat(2, 1fr);
        }

        .lng-hero-img-row {
          grid-template-columns: 1fr 1fr;
        }
      }

      @media(max-width: 600px) {
        .lng-care-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .lng-hero-pills {
          gap: 8px;
        }

        .lng-hero-img-row {
          grid-template-columns: 1fr;
        }

        .lng-conditions-grid,
        .lng-conditions-grid.two,
        .lng-conditions-grid.three,
        .lng-conditions-grid.four {
          grid-template-columns: 1fr;
        }
      }

      /* ── PREMIUM DELIVERY SECTION ── */
      .delivery-section {
        padding: 100px 40px;
        background: linear-gradient(135deg, var(--cream) 0%, rgba(64, 145, 108, 0.08) 100%);
        position: relative;
        overflow: hidden;
      }

      .delivery-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image:
          radial-gradient(circle at 20% 50%, rgba(64, 145, 108, 0.03) 0%, transparent 50%),
          radial-gradient(circle at 80% 80%, rgba(201, 150, 62, 0.02) 0%, transparent 50%);
        pointer-events: none;
      }

      .delivery-section .container {
        position: relative;
        z-index: 1;
      }

      .delivery-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
        margin-top: 64px;
      }

      /* Left: Hero Images */
      .delivery-hero-side {
        position: relative;
        height: 600px;
      }

      .delivery-hero-img {
        position: relative;
        width: 100%;
        height: 100%;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 32px 80px rgba(0, 0, 0, 0.15);
        transition: all 0.4s cubic-bezier(0.23, 1, 0.320, 1);
      }

      .delivery-hero-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
      }

      .delivery-hero-img:hover img {
        transform: scale(1.04);
      }

      /* Floating Cards */
      .delivery-float-cards {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
      }

      .delivery-float-card {
        position: absolute;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.25);
        animation: float 3s ease-in-out infinite;
        transition: all 0.3s ease;
      }

      .delivery-float-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 16px 48px rgba(0, 0, 0, 0.15);
        background: rgba(255, 255, 255, 0.15);
      }

      .delivery-float-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* Float positions */
      .delivery-float-card:nth-child(1) {
        width: 140px;
        height: 140px;
        bottom: -40px;
        left: -30px;
        animation-delay: 0s;
      }

      .delivery-float-card:nth-child(2) {
        width: 120px;
        height: 120px;
        top: 60px;
        right: -50px;
        animation-delay: 0.8s;
      }

      .delivery-float-card:nth-child(3) {
        width: 130px;
        height: 130px;
        bottom: 80px;
        right: -60px;
        animation-delay: 1.6s;
      }

      @keyframes float {
        0%, 100% {
          transform: translateY(0px);
        }
        50% {
          transform: translateY(-20px);
        }
      }

      /* Right: Feature Cards & CTA */
      .delivery-content-side {
        display: flex;
        flex-direction: column;
        gap: 28px;
      }

      .delivery-features {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
      }

      .delivery-feature-card {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(245, 240, 232, 0.9) 100%);
        border: 1px solid rgba(0, 0, 0, 0.05);
        border-radius: 18px;
        padding: 32px;
        display: flex;
        gap: 24px;
        align-items: flex-start;
        transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
        backdrop-filter: blur(8px);
        cursor: pointer;
      }

      .delivery-feature-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08);
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(245, 240, 232, 0.95) 100%);
        border-color: rgba(64, 145, 108, 0.1);
      }

      .delivery-feature-icon {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--green-accent), var(--green-light));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        flex-shrink: 0;
      }

      .delivery-feature-body h3 {
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--green-dark);
        margin-bottom: 6px;
      }

      .delivery-feature-body p {
        font-size: 14px;
        color: var(--text-light);
        line-height: 1.6;
      }

      /* Tamil Nadu Notice */
      .delivery-notice {
        background: linear-gradient(135deg, var(--green-dark) 0%, var(--green-mid) 100%);
        border-radius: 18px;
        padding: 28px;
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(201, 150, 62, 0.3);
      }

      .delivery-notice::before {
        content: '';
        position: absolute;
        top: 0;
        right: 0;
        width: 150px;
        height: 150px;
        background: radial-gradient(circle, rgba(201, 150, 62, 0.1) 0%, transparent 70%);
        border-radius: 50%;
      }

      .delivery-notice-content {
        position: relative;
        z-index: 1;
      }

      .delivery-notice-heading {
        font-family: 'Playfair Display', serif;
        font-size: 22px;
        font-weight: 700;
        color: var(--gold-light);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .delivery-notice-heading::before {
        content: '📍';
        font-size: 24px;
      }

      .delivery-notice-desc {
        font-size: 15px;
        color: rgba(255, 255, 255, 0.85);
        line-height: 1.6;
        margin-bottom: 16px;
      }

      .delivery-notice-highlight {
        background: rgba(201, 150, 62, 0.2);
        border-left: 3px solid var(--gold-light);
        padding: 14px 16px;
        border-radius: 8px;
        margin-bottom: 12px;
        font-weight: 600;
        color: var(--gold-light);
        font-size: 14px;
      }

      .delivery-notice-small {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.65);
        line-height: 1.5;
      }

      /* CTA Buttons */
      .delivery-cta-btns {
        display: flex;
        gap: 16px;
        margin-top: 8px;
      }

      .delivery-cta-btns .btn {
        flex: 1;
        padding: 18px 28px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 15px;
        transition: all 0.3s ease;
      }

      .delivery-cta-btns .btn-gold {
        background: linear-gradient(135deg, var(--gold), var(--gold-light));
        color: var(--green-dark);
        box-shadow: 0 8px 24px rgba(201, 150, 62, 0.15);
      }

      .delivery-cta-btns .btn-gold:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 40px rgba(201, 150, 62, 0.4);
      }

      .delivery-cta-btns .btn-green {
        background: var(--green-mid);
        color: #fff;
        box-shadow: 0 8px 24px rgba(13, 40, 24, 0.15);
      }

      .delivery-cta-btns .btn-green:hover {
        background: var(--green-light);
        transform: translateY(-4px);
        box-shadow: 0 16px 40px rgba(13, 40, 24, 0.3);
      }

      /* Responsive Design */
      @media (max-width: 1024px) {
        .delivery-content {
          grid-template-columns: 1fr;
          gap: 50px;
        }

        .delivery-hero-side {
          height: 450px;
        }

        .delivery-float-card:nth-child(1) {
          width: 120px;
          height: 120px;
          bottom: -25px;
          left: -20px;
        }

        .delivery-float-card:nth-child(2) {
          width: 100px;
          height: 100px;
          top: 50px;
          right: -40px;
        }

        .delivery-float-card:nth-child(3) {
          width: 110px;
          height: 110px;
          bottom: 60px;
          right: -50px;
        }
      }

      @media (max-width: 768px) {
        .delivery-section {
          padding: 60px 24px;
        }

        .delivery-hero-side {
          height: 350px;
        }

        .delivery-feature-card {
          padding: 20px 16px;
          gap: 16px;
        }

        .delivery-feature-icon {
          width: 48px;
          height: 48px;
          font-size: 24px;
        }

        .delivery-feature-body h3 {
          font-size: 16px;
        }

        .delivery-notice {
          padding: 20px;
        }

        .delivery-notice-heading {
          font-size: 18px;
          margin-bottom: 10px;
        }

        .delivery-cta-btns {
          flex-direction: column;
        }

        .delivery-float-card:nth-child(1) {
          width: 100px;
          height: 100px;
          bottom: -20px;
          left: -15px;
        }

        .delivery-float-card:nth-child(2) {
          width: 80px;
          height: 80px;
          top: 40px;
          right: -30px;
        }

        .delivery-float-card:nth-child(3) {
          width: 90px;
          height: 90px;
          bottom: 50px;
          right: -40px;
        }
      }

      @media (max-width: 480px) {
        .delivery-section {
          padding: 50px 16px;
        }

        .delivery-section .section-header {
          margin-bottom: 40px;
        }

        .delivery-hero-side {
          height: 280px;
        }

        .delivery-feature-card {
          padding: 16px 14px;
          gap: 12px;
        }

        .delivery-notice {
          padding: 16px;
        }

        .delivery-float-card:nth-child(1) {
          width: 80px;
          height: 80px;
          display: none;
        }

        .delivery-float-card:nth-child(2) {
          width: 70px;
          height: 70px;
          display: none;
        }

        .delivery-float-card:nth-child(3) {
          width: 75px;
          height: 75px;
          display: none;
        }
      }
    </style>

    <!-- LONGEVITY MODAL -->
    <div id="longevityModal">
      <button class="lng-close-btn" onclick="closeLongevityModal()">✕</button>

      <!-- HERO -->
      <div class="lng-hero">
        <div class="lng-hero-particles" id="lngParticles"></div>
        <div class="lng-hero-content">
          <div class="lng-hero-tag">Life is All About Health</div>
          <h1 class="lng-hero-title"><span class="purple">Longevity</span><br><span class="gold">Life</span></h1>
          <p class="lng-hero-subtitle">Live Longer, Live Better</p>
          <div class="lng-hero-pills">
            <div class="lng-pill">
              <div class="lng-pill-title">Age Reversal</div>
              <div class="lng-pill-sub">Stay Young, Stay Vital</div>
            </div>
            <div class="lng-pill">
              <div class="lng-pill-title">Everlasting Health</div>
              <div class="lng-pill-sub">Wellness for Life</div>
