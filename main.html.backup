  <script>
    function showPage(id) {
      document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
      const t = document.getElementById('page-' + id);
      if (t) { t.classList.add('active'); window.scrollTo({ top: 0, behavior: 'smooth' }); }
    }
    window.addEventListener('scroll', () => {
      document.getElementById('main-header').style.boxShadow =
        window.scrollY > 20 ? '0 4px 24px rgba(0,0,0,.35)' : 'none';
    });

    /* ── CONTACT FORM HANDLER ── */
    (function () {
      var btn = document.getElementById('cf-submit');
      if (!btn) return;
      btn.addEventListener('click', async function () {
        var name = document.getElementById('cf-name').value.trim();
        var email = document.getElementById('cf-email').value.trim();
        var phone = document.getElementById('cf-phone').value.trim();
        var role = document.getElementById('cf-role').value.trim();
        var message = document.getElementById('cf-message').value.trim();
        var feedback = document.getElementById('cf-feedback');

        // Client-side validation
        if (!name || !email || !message) {
          feedback.style.color = '#c0392b';
          feedback.textContent = 'Please fill in your name, email, and message.';
          return;
        }

        // Loading state
        btn.disabled = true;
        btn.textContent = 'Sending…';
        feedback.textContent = '';

        try {
          var res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              fullName: name,
              email: email,
              phone: phone,
              projectType: role,
              projectDetails: message
            })
          });
          var data = await res.json();
          if (data.success) {
            feedback.style.color = '#2d6a4f';
            feedback.textContent = "✓ Message sent! We'll get back to you soon.";
            ['cf-name', 'cf-email', 'cf-phone', 'cf-message'].forEach(function (id) {
              document.getElementById(id).value = '';
            });
            document.getElementById('cf-role').selectedIndex = 0;
          } else {
            var errMsg = data.errors
              ? data.errors.map(function (e) { return e.message; }).join(' ')
              : data.message;
            feedback.style.color = '#c0392b';
            feedback.textContent = errMsg || 'Something went wrong. Please try again.';
          }
        } catch (err) {
          feedback.style.color = '#c0392b';
          feedback.textContent = 'Could not reach the server. Please try again later.';
        } finally {
          btn.disabled = false;
          btn.textContent = 'Send Message →';
        }
      });
    })();

    /* ── LEGAL PAGE ROUTING ── */
    const _legalRoutes = { '/terms-and-conditions': 'terms', '/privacy-policy': 'privacy' };
    function navigateLegal(e, pageId, path) {
      e.preventDefault();
      // Stamp the currently-active page onto the current history entry so
      // pressing Back can restore it correctly.
      var active = document.querySelector('.page.active');
      var prev = active ? active.id.replace('page-', '') : 'home';
      history.replaceState({ page: prev }, '', window.location.pathname);
      showPage(pageId);
      history.pushState({ legalPage: pageId, prevPage: prev }, '', path);
    }
    window.addEventListener('popstate', function (e) {
      if (e.state && e.state.legalPage) {
        // Navigating forward to a legal page (e.g. forward button)
        showPage(e.state.legalPage);
      } else if (e.state && e.state.page) {
        // Navigating back to a regular page (home, csa, etc.)
        showPage(e.state.page);
      } else {
        // Fallback: map URL or default to home
        var mapped = _legalRoutes[window.location.pathname];
        if (mapped) showPage(mapped);
        else showPage('home');
      }
    });
    (function () {
      // Handle direct URL access (e.g. user lands on /terms-and-conditions)
      var stored = sessionStorage.getItem('__chedi_path');
      if (stored) { sessionStorage.removeItem('__chedi_path'); }
      var path = stored || window.location.pathname;
      var mapped = _legalRoutes[path];
      if (mapped) {
        showPage(mapped);
        history.replaceState({ legalPage: mapped }, '', path);
      }
    })();
  </script>


</body>

</html>